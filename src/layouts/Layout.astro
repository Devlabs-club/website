---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import NewFooter from "../components/NewFooter.astro";
import "../styles/global.css";
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta property="og:image" content="/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="DevLabs - Arizona's fastest growing builder community"
    />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta
      property="og:description"
      content="DevLabs is Arizona's most fastest growing builder community—powering the next generation of founders through hacker houses, startup cohorts, and high-energy events. We've hosted 10+ events, backed 50+ startups, and built a 450+ strong network of makers, hackers, and dreamers. This is where Arizona builds"
    />

    <!-- Twitter Card meta tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta
      name="twitter:description"
      content="DevLabs is Arizona's most fastest growing builder community—powering the next generation of founders through hacker houses, startup cohorts, and high-energy events. We've hosted 10+ events, backed 50+ startups, and built a 450+ strong network of makers, hackers, and dreamers. This is where Arizona builds"
    />
    <meta name="twitter:image" content="/og.png" />

    <title>{title}</title>
    <link rel="icon" href="/logo.png" type="image/png" />

    <meta
      name="keywords"
      content="DevLabs, Arizona, startup, events, community, founders, makers, hackers, dreamers, builder, innovation, Arizona State University, DevHacks, DevSpace, DevHouse, startup incubator, early-stage startups, tech startup mentorship, VC connections, startup funding support, founder networking, student tech skills, software engineering training, startup accelerator, tech incubator, entrepreneurship support, startup ecosystem, seed stage startups, venture capital access, build your startup, tech founder support, coding bootcamp for students, startup mentorship program, startup growth support, innovation hub"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://db.onlinewebfonts.com/c/5de0a211c8f197500215b63ee263c25f?family=Mistrully"
      rel="stylesheet"
    />
  </head>
  <body class="text-gray-400 overflow-x-hidden">
    <!-- Fixed background -->
    <div class="fixed inset-0 pointer-events-none z-0">
      <!-- Texture background -->
      <div class="absolute inset-0 bg-texture"></div>
      <!-- Noise texture -->
      <div class="absolute inset-0 bg-noise opacity-[0.06] mix-blend-overlay">
      </div>
    </div>

    <Navbar />
    <main class="relative z-10">
      <slot />
    </main>
    <!-- <Footer /> -->
    <NewFooter />
  </body>
</html>
<style>
  html {
    font-family: Manrope, sans-serif;
  }

  body {
    background-color: transparent;
  }

  .bg-texture {
    background-image: url("/texture.png");
    background-size: cover;
    background-position: center;
    background-repeat: repeat;
  }

  .bg-noise {
    background-image: url("/noise.png");
    background-size: 100px 100px;
    background-repeat: repeat;
  }

  /* Global section parallax: reveal + depth */
  .parallax-section {
    --parallax-offset-y: 0px;
    opacity: 0;
    transform: translateY(calc(56px + var(--parallax-offset-y)));
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .parallax-section.parallax-revealed {
    opacity: 1;
    transform: translateY(var(--parallax-offset-y));
  }
</style>
<script>
  import { initSectionParallax } from "../lib/scroll.js";
  initSectionParallax();
</script>
