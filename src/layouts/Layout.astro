---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import NewFooter from "../components/NewFooter.astro";
import PageLoader from "../components/PageLoader.astro";
import Analytics from "@vercel/analytics/astro";
import "../styles/global.css";
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  keywords?: string;
  hideNavbar?: boolean;
  skipPageLoader?: boolean;
}

const { title, description, ogImage, ogImageAlt, keywords, hideNavbar = false, skipPageLoader = false } = Astro.props;

// Absolute URL required for Twitter/OG image crawlers - relative paths don't work
const siteOrigin = Astro.url.origin;
const defaultDescription =
  "We are the home for builders, founders and vc's to build the future together. Devlabs will be the launchpad for the next generation of student startups.";
const defaultOgImage = `${siteOrigin}/og.jpg`;
const defaultOgImageAlt =
  "Devlabs - The home for builders, founders and vc's to build the future together.";
const defaultKeywords =
  "Devlabs, Arizona, startup, events, community, founders, makers, hackers, dreamers, builder, innovation, Arizona State University, DevHacks, DevSpace, DevHouse, startup incubator, early-stage startups, tech startup mentorship, VC connections, startup funding support, founder networking, student tech skills, software engineering training, startup accelerator, tech incubator, entrepreneurship support, startup ecosystem, seed stage startups, venture capital access, build your startup, tech founder support, coding bootcamp for students, startup mentorship program, startup growth support, innovation hub";

const ogImageUrl = ogImage
  ? ogImage.startsWith("http")
    ? ogImage
    : `${siteOrigin}${ogImage}`
  : defaultOgImage;
const metaDescription = description ?? defaultDescription;
const metaOgImageAlt = ogImageAlt ?? defaultOgImageAlt;
const metaKeywords = keywords ?? defaultKeywords;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={metaDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={metaOgImageAlt} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:description" content={metaDescription} />

    <!-- Twitter Card meta tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <title>{title}</title>
    <link rel="icon" href="/logo.png" type="image/png" />
    <Analytics />

    <meta name="keywords" content={metaKeywords} />

    <slot name="head" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://db.onlinewebfonts.com/c/5de0a211c8f197500215b63ee263c25f?family=Mistrully"
      rel="stylesheet"
    />
  </head>
  <body class:list={['text-gray-400 bg-[hsl(8,8%,3.5%)]', !skipPageLoader && 'loader-visible']}>
    {!skipPageLoader ? <PageLoader /> : null}
    <!-- Fixed background: texture + grain -->
    <div class="fixed inset-0 pointer-events-none z-0">
      <div class="absolute inset-0 bg-texture"></div>
      <div class="absolute inset-0 app-surface-overlay"></div>
      <div class="absolute inset-0 bg-noise opacity-[0.06] mix-blend-overlay"></div>
    </div>

    {!hideNavbar && <Navbar />}
    <main class="relative z-10">
      <slot />
    </main>
    <!-- <Footer /> -->
    <NewFooter />
  </body>
</html>
<style>
  html {
    font-family: Manrope, sans-serif;
  }

  body {
    background-color: hsl(8 8% 3.5%);
  }

  body.loader-visible {
    overflow: hidden;
  }

  /* Global section parallax: reveal + depth */
  .parallax-section {
    --parallax-offset-y: 0px;
    opacity: 0;
    transform: translateY(calc(56px + var(--parallax-offset-y)));
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .parallax-section.parallax-revealed {
    opacity: 1;
    transform: translateY(var(--parallax-offset-y));
  }
</style>
<script>
  import { initSectionParallax } from "../lib/scroll.js";
  initSectionParallax();
</script>
