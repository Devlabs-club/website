---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth overflow-x-hidden">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<meta property="og:image" content="/devlabs-website/logo.svg">
		<link
			rel="icon"
			href="/devlabs-website/logo.svg"
			type="image/x-icon"
		/>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
	</head>
	<body class="text-gray-400 overflow-x-hidden">
		<!-- Fixed background with full-width gradient -->
		<div class="fixed inset-0 bg-neutral-950 pointer-events-none z-0">
			<!-- Full-width gradient overlay -->
			<div class="absolute inset-0 bg-gradient-to-r from-neutral-950 via-neutral-900 to-neutral-950"></div>
			<!-- Noise texture -->
			<div class="absolute inset-0 bg-noise opacity-40"></div>
		</div>
		
		<Navbar />
		<slot />
		<Footer />
	</body>
</html>
<style is:global>
	html {
		font-family: Manrope, sans-serif;
	}

	body {
		background-color: #080808;
	}

	.bg-noise {
		background-image: url('/noise.png');
		background-size: 200px 200px;
		background-repeat: repeat;
		background-position: center;
		width: 100vw;
		height: 100vh;
	}
</style>
