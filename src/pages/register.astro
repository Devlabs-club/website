---
import RegisterPage from '../components/RegisterPage';
import Highlight from '../components/text/Highlight.astro';

const title = 'Register - DevLabs';
const description = 'Create your DevLabs account';
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=Caveat:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
</head>

<body class="bg-neutral-950 text-gray-400 min-h-screen overflow-x-hidden">
    <main class="min-h-screen relative overflow-hidden">
        <!-- Gradient Spheres -->
        <div class="absolute inset-0 overflow-hidden">
            <!-- Primary sphere -->
            <div
                class="sphere-gradient absolute w-[500px] h-[500px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"
            >
            </div>
            <!-- Secondary spheres -->
            <div
                class="sphere-gradient-sm absolute w-[300px] h-[300px] top-[20%] right-[10%]"
            >
            </div>
            <div
                class="sphere-gradient-sm absolute w-[250px] h-[250px] bottom-[15%] left-[5%]"
            >
            </div>
        </div>

        <div
            class="max-w-7xl mx-auto py-24 md:py-32 pb-12 px-4 sm:px-6 lg:px-8 relative z-10"
        >
            <div class="text-center mb-12">
                <a href="/" class="inline-block group mb-8">
                    <img src="/logo.svg" alt="DevLabs" class="h-12 mx-auto group-hover:scale-110 transition-transform duration-200" />
                </a>
                <h1
                    class="text-4xl font-extrabold text-white sm:text-5xl sm:tracking-tight lg:text-6xl"
                >
                    Join Our <Highlight>Community</Highlight>
                </h1>
                <p class="mt-5 max-w-xl mx-auto text-xl text-gray-300">
                    Create your account to get started and become part of our amazing developer community.
                </p>
            </div>

            <div class="max-w-md mx-auto">
                <RegisterPage client:load />

                <div class="text-center mt-6">
                    <a href="/" class="text-orange-400 hover:text-orange-300 transition-colors duration-200 flex items-center justify-center gap-2">
                        <span>←</span> Back to Home
                    </a>
                </div>
            </div>
        </div>
    </main>
</body>
</html>

<style>
    html {
        font-family: Manrope, sans-serif;
    }

    body {
        background-color: #111;
    }

    /* Gradient Spheres */
    .sphere-gradient {
        background: radial-gradient(
            circle at center,
            rgba(255, 153, 0, 0.15) 0%,
            transparent 70%
        );
        filter: blur(60px);
        border-radius: 50%;
        animation: float 8s ease-in-out infinite;
    }

    .sphere-gradient-sm {
        background: radial-gradient(
            circle at center,
            rgba(255, 153, 0, 0.1) 0%,
            transparent 70%
        );
        filter: blur(40px);
        border-radius: 50%;
        animation: float 12s ease-in-out infinite reverse;
    }

    @keyframes float {
        0%,
        100% {
            transform: translate(0, 0);
        }
        50% {
            transform: translate(20px, -20px);
        }
    }
</style>
