---
import RegisterPage from '../components/RegisterPage';

const title = 'Register - DevLabs';
const description = 'Create your DevLabs account';
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=Caveat:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
</head>

<body class="bg-neutral-950 text-gray-400 min-h-screen overflow-x-hidden">
    <!-- Fixed background with noise texture -->
    <div class="fixed inset-0 bg-neutral-950 pointer-events-none z-0">
        <div class="absolute inset-0 bg-gradient-to-r from-neutral-950 via-neutral-900 to-neutral-950"></div>
        <div class="absolute inset-0 bg-noise opacity-40"></div>
    </div>

    <!-- Floating gradient orbs -->
    <div class="absolute top-1/4 right-1/4 w-32 h-32 bg-orange-500/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 left-1/4 w-24 h-24 bg-orange-400/10 rounded-full blur-2xl animate-pulse delay-1000"></div>

    <div class="relative z-10 container mx-auto px-4 py-8">
        <div class="max-w-md mx-auto">
            <div class="text-center mb-8">
                <a href="/" class="inline-block group">
                    <img src="/logo.svg" alt="DevLabs" class="h-12 mx-auto mb-4 group-hover:scale-110 transition-transform duration-200" />
                </a>
                <h1 class="text-3xl font-bold text-white mb-2">Join DevLabs</h1>
                <p class="text-gray-400">Create your account to get started</p>
            </div>

            <RegisterPage client:load />

            <div class="text-center mt-6">
                <a href="/" class="text-orange-400 hover:text-orange-300 transition-colors duration-200 flex items-center justify-center gap-2">
                    <span>←</span> Back to Home
                </a>
            </div>
        </div>
    </div>
</body>
</html>

<style>
    html {
        font-family: Manrope, sans-serif;
    }

    body {
        background-color: #080808;
    }

    .bg-noise {
        background-image: url("/noise.png");
        background-size: 200px 200px;
        background-repeat: repeat;
        background-position: center;
    }
</style>
