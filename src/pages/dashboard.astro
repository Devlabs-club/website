---
import DashboardPage from '../components/DashboardPage';

const title = 'Dashboard - DevLabs';
const description = 'Your DevLabs dashboard';
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=Caveat:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
</head>

<body class="bg-neutral-950 text-gray-400 overflow-x-hidden">
    <DashboardPage client:load />
</body>
</html>

<style>
    html {
        font-family: Manrope, sans-serif;
    }

    body {
        background-color: #080808;
    }

    .bg-noise {
        background-image: url("/noise.png");
        background-size: 200px 200px;
        background-repeat: repeat;
        background-position: center;
    }
</style>
