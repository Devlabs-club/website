---
import Layout from '../layouts/Layout.astro';

// Event data (detailed view)
const events = [
  {
    id: 'devhouse-sf',
    name: 'DevHouse SF',
    tagline: 'SF’s Biggest Hiring Stunt',
    description: 'DevHouse SF was a hacker house designed to immerse top 100 student builders in San Francisco’s startup ecosystem with one clear objective: to change the way startups hire. The top 100 builders live and work on problem statements from the sponsor companies.',
    image: '/events/devhouse-sf.jpg',
    stats: {
      builders: '100',
      incash: '$10,000',
      hired: '1 ',
      interview: '8'
    },
    partners: ['/sponsors/deepmind.png', '/sponsors/browser-use.png', '/sponsors/airgarage.png', '/sponsors/omi.png', '/sponsors/supermemory.png', '/sponsors/standout.png'],
    highlights: ['Hiring', 'Buidler Energy', ' Hacker House'],
    date: 'Summer 2025',
    status: 'completed',
    link: 'https://devhouse.devlabs.club'
  },
  {
    id: 'devhouse',
    name: 'DevHouse',
    tagline: 'Arizona\'s First Hacker House',
    description: 'DevHouse is our residential program where selected builders live together for 6 weeks, working on their projects while building lasting friendships. It\'s an intensive experience that combines living, learning, and building in a collaborative environment.',
    image: '/events/devhouse.jpeg',
    stats: {
      residents: '12',
      weeks: '6',
      projects: '8',
      funding: '$50,000+'
    },
partners: ['/sponsors/loloft.png', '/sponsors/azvc.png', '/sponsors/phxventures.webp', '/sponsors/aca.png','/sponsors/siliconoasis.png'],
    highlights: ['Residential Program', 'Daily Standups', 'Project Showcase', 'Investor Demo Day'],
    date: 'Summer 2025',
    status: 'completed',
    link: 'https://www.gpec.org/news/press-releases/devlabs-launches-hacker-house/'
  },
  {
    id: 'devhacks',
    name: 'DevHacks',
    tagline: 'One hackathon. Infinite possibilities.',
    description: 'DevHacks is our premier hackathon that challenges participants to build innovative solutions to real-world problems. Teams work around the clock to create prototypes, learn new technologies, and compete for exciting prizes.',
    image: '/events/devhacks.jpg',
    stats: {
      participants: '180+',
      applications: '350+',
      projects: '50',
      sponsorship: '$25,000'
    },
    partners: ['/sponsors/ph.png', '/sponsors/browser-use.png', '/sponsors/supermemory.png'],
    highlights: ['48-Hour Build', 'Mentor Support', 'Pitch Competition', 'Cash Prizes'],
    date: 'Spring 2025',
    status: 'completed',
    link: 'https://devhacks.devlabs.club'
  },
  {
    id: 'devspace',
    name: 'DevSpace',
    tagline: 'Go Big @ ASU',
    description: 'DevSpace is our flagship networking and learning event that brings together Arizona\'s brightest developers, designers, and entrepreneurs. A day filled with workshops, lightning talks, and networking opportunities.<br><br> Special thanks to <a href="https://www.linkedin.com/in/hamidshojaee/" target="_blank" rel="noopener noreferrer" class="text-orange-400 hover:text-orange-300 underline underline-offset-2 font-medium">Hamid Shojaee</a> for his support and belief in our mission—we\'re grateful for everything he did to make Devspace possible.',
    image: '/events/devspace.png',
    stats: {
      participants: '60+',
      speakers: '7',
      workshops: '5',
      collaborations: '25+'
    },
    partners: [ '/sponsors/e+i.png'],
    highlights: ['Networking Sessions', 'Technical Workshops', 'Startup Pitches', 'Mentorship Opportunities'],
    date: 'Fall 2024',
    status: 'completed',
    link: 'https://devspace.devlabs.club'
    }
];
---

<Layout title="Events - DevLabs Signature Experiences">
    <div class="bg-[#0a0a0a] min-h-screen text-white overflow-x-hidden font-sans">
        
        <!-- Background: texture.png (main) + noise overlay -->
        <div class="events-bg-texture fixed inset-0 z-0 pointer-events-none"></div>
        <div class="fixed inset-0 z-0 opacity-[0.06] pointer-events-none mix-blend-overlay events-bg-noise"></div>

        <!-- Hero Section -->
        <div class="relative z-10 pt-32 pb-20 px-6 text-center">
            <h1 class="text-6xl md:text-8xl font-bold tracking-tighter mb-6 text-white">
                Our <span class="relative inline-block text-white">
                    Events
                    <svg class="absolute w-full h-4 -bottom-2 left-0 text-orange-500" viewBox="0 0 100 10" preserveAspectRatio="none">
                        <path d="M0 5 Q 50 10 100 5" stroke="currentColor" stroke-width="8" fill="none" />
                    </svg>
                </span>
            </h1>
            <p class="text-xl text-gray-400 max-w-2xl mx-auto font-light">
                From hackathons to hacker houses, discover the experiences that define the DevLabs community.
            </p>
        </div>

        <!-- Events List -->
        <div class="relative z-10 flex flex-col gap-40 pb-32 max-w-7xl mx-auto px-6">
            {events.map((event, index) => (
                <section class={`flex flex-col lg:flex-row items-center gap-16 lg:gap-24 ${index % 2 !== 0 ? 'lg:flex-row-reverse' : ''}`}>
                    
                    <!-- Polaroid Image (Left) -->
                    <div class="w-full lg:w-5/12 flex justify-center perspective-1000">
                        <div class="relative group cursor-pointer transform transition-all duration-700 hover:rotate-0 hover:scale-105 rotate-[-2deg]">
                            <!-- Polaroid Frame -->
                            <div class="bg-white p-5 pb-20 shadow-2xl max-w-md w-full mx-auto transform transition-transform duration-500 relative z-10">
                                <div class="aspect-[4/5] overflow-hidden bg-gray-100 relative">
                                    {event.image ? (
                                        <img 
                                            src={event.image} 
                                            alt={event.name}
                                            class="w-full h-full object-cover filter sepia-[0.1] contrast-110 group-hover:sepia-0 transition-all duration-700"
                                        />
                                    ) : (
                                        <div class="w-full h-full bg-gradient-to-br from-gray-800 to-black"></div>
                                    )}
                                    <!-- Grain overlay on image -->
                                    <div class="absolute inset-0 bg-noise opacity-10 mix-blend-overlay pointer-events-none"></div>
                                    
                                    <!-- Shine effect -->
                                    <div class="absolute inset-0 bg-gradient-to-tr from-white/0 via-white/10 to-white/0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
                                </div>
                                <div class="absolute bottom-6 left-0 right-0 text-center">
                                    <h3 class="text-black font-bold text-5xl tracking-tighter font-sans">{event.name}</h3>
                                </div>
                            </div>
                            
                            <!-- Shadow/Depth layers -->
                            <div class="absolute -z-10 top-2 -right-2 w-full h-full bg-black/50 blur-xl transform rotate-2"></div>
                        </div>
                    </div>

                    <!-- Content (Right) -->
                    <div class="w-full lg:w-7/12 space-y-10">
                        <div>
                            <h2 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tight mb-8 text-white">
                                <span class="relative inline">
                                    {event.tagline}
                                    <span class="absolute bottom-1 left-0 w-full h-[0.2em] bg-orange-500 -z-10 transform -rotate-1 opacity-80 mix-blend-screen"></span>
                                </span>
                            </h2>
                            <p class="text-xl md:text-2xl text-gray-300 leading-relaxed font-light max-w-2xl">
                                <p class="text-xl md:text-2xl text-gray-300 leading-relaxed font-light max-w-2xl [&_a]:text-orange-400 [&_a]:hover:text-orange-300 [&_a]:underline [&_a]:underline-offset-2 [&_a]:font-medium" set:html={event.description}></p>
                            </p>
                        </div>

                        <!-- Trusted By -->
                        {event.partners && event.partners.length > 0 && (
                            <div class="border-t border-white/10 pt-8">
                                <div class="text-xs text-gray-500 uppercase tracking-[0.2em] font-bold mb-6">
                                    Sponsored by
                                </div>
                                <div class="flex flex-wrap items-center gap-8 md:gap-12 opacity-70 hover:opacity-100 transition-opacity duration-300">
                                    {event.partners.map(logo => (
                                        <img src={logo} alt="Partner" class="h-5 md:h-6 w-auto object-contain brightness-0 invert" />
                                    ))}
                                </div>
                            </div>
                        )}

                        <!-- Stats Grid (Optional, if no partners or in addition) -->
                        {!event.partners && (
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 border-t border-white/10 pt-8">
                                {Object.entries(event.stats).map(([key, value]) => (
                                    <div>
                                        <div class="text-3xl font-bold text-white mb-1">{value}</div>
                                        <div class="text-xs text-gray-500 uppercase tracking-wider">{key}</div>
                                    </div>
                                ))}
                            </div>
                        )}

                        <!-- Action -->
                        <div class="pt-2">
                            <a 
                                href={event.link || '#'} 
                                target={event.link?.startsWith('http') ? '_blank' : undefined}
                                class="inline-flex items-center gap-3 bg-[#1a1a1a] hover:bg-[#252525] border border-white/10 hover:border-white/30 text-white px-8 py-4 rounded-full text-lg font-medium transition-all duration-300 group"
                            >
                                <span>Visit Website</span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform text-gray-400 group-hover:text-white">
                                    <line x1="7" y1="17" x2="17" y2="7"></line>
                                    <polyline points="7 7 17 7 17 17"></polyline>
                                </svg>
                            </a>
                        </div>
                    </div>

                </section>
            ))}
        </div>
    </div>
</Layout>

<style>
    .perspective-1000 {
        perspective: 1000px;
    }
    .events-bg-texture {
        background-image: url('/texture.png');
        background-size: cover;
        background-position: center;
        background-repeat: repeat;
    }
    .events-bg-noise {
        background-image: url('/noise.png');
        background-size: 100px 100px;
        background-repeat: repeat;
    }
    .bg-noise {
        background-image: url('/noise.png');
        background-size: 100px 100px;
    }
</style>
