---
import Layout from '../layouts/Layout.astro';

import GradientBlob from '../components/GradientBlob.astro';
import Highlight from '../components/text/Highlight.astro';
import EventsParallax from '../components/Events.astro';
import EventsShowcase from '../components/EventsShowcase.astro';

// Event data (detailed view)
const events = [
  {
    id: 'devhouse-sf',
    name: 'DevHouse SF',
    tagline: 'SF\'s biggest hiring stunt ',
    description: 'DevHouse SF was a hacker house designed to immerse top 100 student builders in San Francisco’s startup ecosystem with one clear objective: to change the way startups hire. The top 100 builders live and work on problem statements from the sponsor companies and the end goals were ',
    image: '/events/devhouse-sf.jpg',
    stats: {
      builders: '100',
      incash: '$10,000',
      hired: '1 ',
      interview: '8'
    },
    highlights: ['Hiring', 'Buidler Energy', ' Hacker House'],
    date: 'Summer 2025',
    status: 'completed',
    link: 'https://devhouse.devlabs.club'
  },
  {
    id: 'devhouse',
    name: 'DevHouse',
    tagline: 'Live, Build, Grow Together',
    description: 'DevHouse is our residential program where selected builders live together for 6 weeks, working on their projects while building lasting friendships. It\'s an intensive experience that combines living, learning, and building in a collaborative environment.',
    image: '/events/devhouse.jpeg',
    stats: {
      residents: '12',
      weeks: '6',
      projects: '8',
      funding: '$50,000+'
    },
    highlights: ['Residential Program', 'Daily Standups', 'Project Showcase', 'Investor Demo Day'],
    date: 'Summer 2025',
    status: 'completed',
    link: 'https://www.gpec.org/news/press-releases/devlabs-launches-hacker-house/'
  },
  {
    id: 'devhacks',
    name: 'DevHacks',
    tagline: 'Build Something Amazing in 48 Hours',
    description: 'DevHacks is our premier hackathon that challenges participants to build innovative solutions to real-world problems. Teams work around the clock to create prototypes, learn new technologies, and compete for exciting prizes.',
    image: '/events/devhacks.jpg',
    stats: {
      participants: '180+',
      applications: '350+',
      projects: '50',
      sponsorship: '$25,000'
    },
    highlights: ['48-Hour Build', 'Mentor Support', 'Pitch Competition', 'Cash Prizes'],
    date: 'Spring 2025',
    status: 'completed',
    link: 'https://entrepreneurship.engineering.asu.edu/2025/06/devhacks-2025-ignites-innovation-at-arizona-state-university/'
  },
  {
    id: 'devspace',
    name: 'DevSpace',
    tagline: 'Where Innovation Meets Collaboration',
    description: 'DevSpace is our flagship networking and learning event that brings together Arizona\'s brightest developers, designers, and entrepreneurs. A day filled with workshops, lightning talks, and networking opportunities that spark new collaborations and friendships.',
    image: '/events/devspace.jpg',
    stats: {
      participants: '60+',
      speakers: '7',
      workshops: '5',
      collaborations: '25+'
    },
    highlights: ['Networking Sessions', 'Technical Workshops', 'Startup Pitches', 'Mentorship Opportunities'],
    date: 'Fall 2024',
    status: 'completed',
    link: ''
  },
  {
    id: 'momentum',
    name: 'Momentum',
    tagline: 'Launch your startup. For real.',
    description: 'Momentum is our new startup program—a cohort-based, mentor-led experience for early-stage founders. Get direct access to investors, the DevLabs network, and the support to take your idea from prototype to launch.',
    image: null,
    stats: {
      cohort: 'TBD',
      duration: '12 weeks',
      mentors: '10+',
      funding: 'Up to $50K'
    },
    highlights: ['Cohort-Based', 'Mentor-Led', 'Investor Access', 'DevLabs Network'],
    date: 'Cohort 1 coming soon',
    status: 'upcoming',
    link: '#momentum'
  },
];
---

<Layout title="Events - DevLabs Signature Experiences">
    
    <!-- Hero Section -->
    <div class="min-h-[60vh] flex items-center justify-center relative overflow-hidden pt-24 md:pt-32 pb-12">
        <GradientBlob top="-20%" right="-10%" left="" scale="1.5" />
        <GradientBlob top="60%" left="-15%" right="" scale="1.2" />
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center">
                <h1 class="text-5xl md:text-6xl font-bold text-white leading-tight mb-6">
                    Our <Highlight>Signature Events</Highlight>
                </h1>
                <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
                    From hackathons to hacker houses, discover the experiences that define the DevLabs community.
                </p>
            </div>
        </div>
    </div>

    <EventsShowcase />

    <EventsParallax />

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-10 text-center md:text-left">
            Explore in detail
        </h2>
        <!-- Events Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16">
            {events.map((event) => (
            <a target={event.link?.startsWith('http') ? '_blank' : undefined} href={event.link || '#'} id={event.id === 'momentum' ? 'momentum' : undefined}>
                <div class="group relative bg-gradient-to-br from-white/5 via-white/3 to-transparent border border-white/10 backdrop-blur-sm rounded-3xl p-6 hover:border-orange-400/30 hover:bg-gradient-to-br hover:from-orange-500/10 hover:via-orange-400/5 hover:to-transparent transition-all duration-500 hover:scale-[1.02] hover:shadow-orange-500/20">
                    <!-- Event Image -->
                    <div class="relative mb-6 overflow-hidden rounded-2xl">
                        {event.image ? (
                        <img 
                            src={event.image} 
                            alt={event.name}
                            class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-500"
                        />
                        ) : (
                        <div class="w-full h-64 bg-gradient-to-br from-orange-900/40 via-amber-900/30 to-black group-hover:scale-105 transition-transform duration-500"></div>
                        )}
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
                        
                        <!-- Status Badge -->
                        <div class="absolute top-4 right-4">
                            {event.status === 'upcoming' ? (
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-base font-medium bg-green-500/30 text-green-300 border border-green-500/40">
                                    Upcoming
                                </span>
                            ) : (
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-base font-medium bg-blue-500/30 text-blue-300 border border-blue-500/40">
                                    Completed
                                </span>
                            )}
                        </div>
                    </div>

                    <!-- Event Content -->
                    <div class="space-y-4">
                        <!-- Event Header -->
                        <div>
                            <h3 class="text-4xl font-bold text-white mb-2 group-hover:text-orange-300 transition-colors">
                                {event.name}
                            </h3>
                            <p class="text-orange-400 text-xl font-medium mb-2">{event.tagline}</p>
                            <p class="text-gray-400 text-lg">{event.date}</p>
                        </div>

                        <!-- Description -->
                        <p class="text-gray-300 text-xl leading-relaxed">
                            {event.description}
                        </p>

                        <!-- Stats Grid -->
                        <div class="grid grid-cols-2 gap-4 py-4">
                            {Object.entries(event.stats).map(([key, value]) => (
                                <div class="text-center">
                                    <div class="text-4xl font-bold text-orange-400 mb-1">{value}</div>
                                    <div class="text-base text-gray-400 capitalize">{key}</div>
                                </div>
                            ))}
                        </div>

                        <!-- Highlights -->
                        <div class="flex flex-wrap gap-2">
                            {event.highlights.map((highlight) => (
                                <span class="inline-flex items-center px-2 py-1 rounded-full text-base bg-white/10 text-white/80 border border-white/20">
                                    {highlight}
                                </span>
                            ))}
                        </div>
                    </div>

                    <!-- Hover Glow Effect -->
                    <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-orange-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
                </div>
            </a>
            ))}
        </div>
    </div>

</Layout> 