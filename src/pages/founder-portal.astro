---
import Layout from '@/layouts/Layout.astro';
import ConversationalShell from '@/components/portal/ConversationalShell';
---

<Layout title="Founder Portal · DevLabs">
  <main class="relative pt-44 pb-24 px-4 md:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="mb-10">
        <p class="text-[#fa7d22] uppercase tracking-[0.2em] text-xs font-semibold">Founder OS</p>
        <h1 class="text-white text-5xl md:text-7xl leading-[0.95] mt-3">
          tell us what you're building,
          <span class="block font-[Mistrully] italic">we’ll find who can ship it</span>
        </h1>
        <p class="text-white/60 mt-5 max-w-3xl text-lg">Conversational founder intake that generates role briefs, structured search criteria, and shortlist cards with proof-of-work.</p>
      </div>

      <ConversationalShell
        client:load
        title="Founder Intake & Matching Agent"
        subtitle="Describe your startup and role in plain text. I’ll create a role brief and run a search."
        options={[
          {
            label: 'Create Role Brief',
            action: 'create_role_brief',
            placeholder: 'company | role title | startup summary | skills(csv) | budget | timeline | work type',
          },
          {
            label: 'Run Candidate Search',
            action: 'run_candidate_search',
            placeholder: 'Paste the opportunity ID generated above',
          },
        ]}
      />
    </div>
  </main>
</Layout>
