---
import Layout from "../layouts/Layout.astro";
import ClientForm from "../components/ClientForm";
import GradientBlob from "../components/GradientBlob.astro";
import WrappedText from "../components/text/WrappedText.astro";
import Highlight from "../components/text/Highlight.astro";
---

<Layout title="Share Your Job Requirements">
  <div
    class="min-h-screen flex items-center justify-center relative overflow-hidden py-24 md:py-32"
  >
    <GradientBlob top="-20%" right="-10%" left="" scale="1.5" />
    <GradientBlob top="60%" left="-15%" right="" scale="1.2" />

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="hidden md:flex flex-col lg:flex-row lg:justify-between lg:items-center w-full mb-16 gap-8 lg:gap-0"
      >
        <h1
          class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight md:text-center lg:text-left text-left"
        >
          Share your roles with us<br />
          <Highlight>and tap into builder energy</Highlight>
        </h1>
      </div>

      <div
      class="md:hidden  flex-col lg:flex-row lg:justify-between lg:items-center w-full mb-16 gap-8 lg:gap-0"
    >
      <h1
        class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight md:text-center lg:text-left text-left"
      >
        Tap into the <br />
        <Highlight>builder community</Highlight>
      </h1>
    </div>
      <div class="w-full mb-16">
        <div
          class="w-full h-[450px] md:h-[550px] bg-white/20 rounded-3xl p-2 shadow-2xl overflow-hidden backdrop-blur-sm border-2 border-dashed border-white/30 relative"
        >
          <img
            src="events/DevHacks4.jpg"
            alt="Hire"
            class="w-full h-full object-cover opacity-70 rounded-2xl"
          />
          <div
            class="absolute inset-0 bg-gradient-to-br from-orange-500/30 via-orange-400/20 to-orange-300/15 rounded-2xl"
          >
          </div>

          <svg
            class="absolute inset-0 w-full h-full"
            viewBox="0 0 400 300"
            fill="none"
          >
            <path
              d="M50 50 Q200 100 350 80"
              stroke="#f97316"
              stroke-width="2"
              fill="none"
              opacity="0.6"></path>
            <path
              d="M30 120 Q180 160 320 140"
              stroke="#f97316"
              stroke-width="2"
              fill="none"
              opacity="0.4"></path>
            <path
              d="M70 200 Q220 240 370 220"
              stroke="#f97316"
              stroke-width="2"
              fill="none"
              opacity="0.5"></path>
          </svg>

          <div
            class="absolute right-8 top-8 bottom-8 z-20 flex flex-col justify-between"
          >
            <div
              class="relative bg-black/80 backdrop-blur-xl border border-gray-700/50 rounded-xl p-4 shadow-2xl min-w-48 transform rotate-3 hover:rotate-0 transition-all duration-300 hover:scale-105 hover:shadow-[0_20px_60px_rgba(0,0,0,0.8)] group"
            >
              <div
                class="absolute inset-0 bg-gradient-to-br from-black/60 via-black/40 to-transparent rounded-xl"
              >
              </div>
              <div class="relative z-10">
                <div class="flex items-center mb-2">
                  <div
                    class="w-8 h-8 bg-orange-500/30 rounded-full flex items-center justify-center mr-3 group-hover:bg-orange-500/50 transition-colors"
                  >
                    <svg
                      class="w-4 h-4 text-orange-300"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                      ></path>
                    </svg>
                  </div>
                  <span class="text-lg font-bold text-white drop-shadow-sm"
                    >150+</span
                  >
                </div>
                <p class="text-sm text-gray-200 drop-shadow-sm">
                  Vetted builders ready
                </p>
                <div class="flex items-center mt-2">
                  <div class="w-16 h-2 bg-gray-700/50 rounded-full">
                    <div class="w-12 h-2 bg-orange-400 rounded-full shadow-sm">
                    </div>
                  </div>
                  <span class="text-xs text-gray-300 ml-2 drop-shadow-sm"
                    >85% match rate</span
                  >
                </div>
              </div>
            </div>

            <div
              class="relative bg-black/80 backdrop-blur-xl border border-gray-700/50 rounded-xl p-4 shadow-2xl min-w-52 transform -rotate-2 hover:rotate-0 transition-all duration-300 hover:scale-105 hover:shadow-[0_20px_60px_rgba(0,0,0,0.8)] group"
            >
              <div
                class="absolute inset-0 bg-gradient-to-br from-black/60 via-black/40 to-transparent rounded-xl"
              >
              </div>
              <div class="relative z-10">
                <div class="flex items-center mb-2">
                  <div
                    class="w-8 h-8 bg-green-500/30 rounded-full flex items-center justify-center mr-3 group-hover:bg-green-500/50 transition-colors"
                  >
                    <svg
                      class="w-4 h-4 text-green-300"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-lg font-bold text-white drop-shadow-sm"
                    >6-week</span
                  >
                </div>
                <p class="text-sm text-gray-200 drop-shadow-sm">
                  MVP sprint program
                </p>
                <div class="mt-2">
                  <span
                    class="inline-flex items-center px-2 py-1 rounded-full text-xs bg-green-500/30 text-green-300 border border-green-500/40 drop-shadow-sm"
                  >
                    Pre-vetted
                  </span>
                </div>
              </div>
            </div>
          </div>

          <div class="absolute right-44 top-28 z-20 hidden md:block">
            <div
              class="relative bg-black/80 backdrop-blur-xl border border-gray-700/50 rounded-xl p-4 shadow-2xl min-w-52 transform rotate-1 hover:rotate-0 transition-all duration-300 hover:scale-105 hover:shadow-[0_20px_60px_rgba(0,0,0,0.8)] group"
            >
              <div
                class="absolute inset-0 bg-gradient-to-br from-black/60 via-black/40 to-transparent rounded-xl"
              >
              </div>
              <div class="relative z-10">
                <div class="flex items-center mb-2">
                  <div
                    class="w-8 h-8 bg-blue-500/30 rounded-full flex items-center justify-center mr-3 group-hover:bg-blue-500/50 transition-colors"
                  >
                    <svg
                      class="w-4 h-4 text-blue-300"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
                      ></path>
                    </svg>
                  </div>
                  <span class="text-lg font-bold text-white drop-shadow-sm"
                    >Builder</span
                  >
                </div>
                <p class="text-sm text-gray-200 drop-shadow-sm">
                  Engineers, designers, PMs
                </p>
                <div class="mt-2">
                  <span
                    class="inline-flex items-center px-2 py-1 rounded-full text-xs bg-blue-500/30 text-blue-300 border border-blue-500/40 drop-shadow-sm"
                  >
                    Creative minds
                  </span>
                </div>
              </div>
            </div>
          </div>

          <div class="absolute right-8 bottom-1/3 z-20 hidden lg:block">
            <div
              class="relative bg-black/80 backdrop-blur-xl border border-gray-700/50 rounded-xl p-4 shadow-2xl min-w-48 transform -rotate-1 hover:rotate-0 transition-all duration-300 hover:scale-105 hover:shadow-[0_20px_60px_rgba(0,0,0,0.8)] group"
            >
              <div
                class="absolute inset-0 bg-gradient-to-br from-black/60 via-black/40 to-transparent rounded-xl"
              >
              </div>
              <div class="relative z-10">
                <div class="flex items-center mb-2">
                  <div
                    class="w-8 h-8 bg-purple-500/30 rounded-full flex items-center justify-center mr-3 group-hover:bg-purple-500/50 transition-colors"
                  >
                    <svg
                      class="w-4 h-4 text-purple-300"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <span class="text-lg font-bold text-white drop-shadow-sm"
                    >Fresh</span
                  >
                </div>
                <p class="text-sm text-gray-200 drop-shadow-sm">
                  Internships & part-time
                </p>
                <div class="flex items-center mt-2">
                  <div class="w-16 h-2 bg-gray-700/50 rounded-full">
                    <div class="w-10 h-2 bg-purple-400 rounded-full shadow-sm">
                    </div>
                  </div>
                  <span class="text-xs text-gray-300 ml-2 drop-shadow-sm"
                    >Available now</span
                  >
                </div>
              </div>
            </div>
          </div>

          <div class="absolute right-52 top-1/2 z-20 hidden xl:block">
            <div
              class="relative bg-black/80 backdrop-blur-xl border border-gray-700/50 rounded-xl p-4 shadow-2xl min-w-56 transform rotate-2 hover:rotate-0 transition-all duration-300 hover:scale-105 hover:shadow-[0_20px_60px_rgba(0,0,0,0.8)] group"
            >
              <div
                class="absolute inset-0 bg-gradient-to-br from-black/60 via-black/40 to-transparent rounded-xl"
              >
              </div>
              <div class="relative z-10">
                <div class="flex items-center mb-2">
                  <div
                    class="w-8 h-8 bg-yellow-500/30 rounded-full flex items-center justify-center mr-3 group-hover:bg-yellow-500/50 transition-colors"
                  >
                    <svg
                      class="w-4 h-4 text-yellow-300"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                  </div>
                  <span class="text-lg font-bold text-white drop-shadow-sm"
                    >Easy</span
                  >
                </div>
                <p class="text-sm text-gray-200 drop-shadow-sm">
                  Post openings & connect
                </p>
                <div class="mt-2">
                  <span
                    class="inline-flex items-center px-2 py-1 rounded-full text-xs bg-yellow-500/30 text-yellow-300 border border-yellow-500/40 drop-shadow-sm"
                  >
                    Quick access
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div
        class="flex flex-col sm:flex-row justify-between items-center sm:items-end w-full gap-6 sm:gap-0"
      >
        <div class="flex items-end">
          <span
            class="text-6xl sm:text-8xl md:text-10xl lg:text-[12rem] font-bold bg-gradient-to-r from-orange-500 to-orange-300 text-transparent bg-clip-text leading-none"
            >350+</span
          >
          <span
            class="text-lg sm:text-xl lg:text-2xl text-white ml-2 mb-2 sm:mb-4"
            >builder community</span
          >
        </div>
        <div class="text-center sm:text-right">
          <div class="flex flex-wrap gap-2 justify-center sm:justify-end">
            <WrappedText
              size="large"
              className="border-orange-300 text-orange-300"
            >
              founders</WrappedText
            >
            <WrappedText
              size="large"
              className="border-orange-300 text-orange-300"
            >
              recent grads</WrappedText
            >
            <WrappedText
              size="large"
              className="border-orange-300 text-orange-300"
            >
              indie hackers</WrappedText
            >
            <WrappedText
              size="large"
              className="border-orange-300 text-orange-300"
            >
              previous founders</WrappedText
            >
          </div>
        </div>
      </div>

      <div class="mt-16 text-center">
        <div class="mb-8">
          <WrappedText size="normal" className=""
            >why hire from devlabs?</WrappedText
          >
        </div>

        <p
          class="text-lg sm:text-xl text-gray-300 max-w-4xl mx-auto leading-relaxed mb-8"
        >
          Looking for interns, early hires, or fresh perspectives? DevLabs works
          with some of the most driven, technical, and startup-minded students
          at ASU and nearby universities. <Highlight
            >Share your roles and we’ll line up your next great hire.</Highlight
          >
        </p>

        <div class="relative max-w-4xl mx-auto">
          <div
            class="absolute -inset-0.5 bg-gradient-to-r from-orange-500/20 via-orange-400/20 to-orange-300/20 blur-3xl opacity-60"
          >
          </div>
          <div
            id="client-form"
            class="relative bg-black/70 backdrop-blur-xl border border-white/10 rounded-3xl p-6 sm:p-8 shadow-[0_20px_60px_rgba(0,0,0,0.6)]"
          >
       
            <ClientForm client:load />
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
