---
import Layout from "../../layouts/Layout.astro";
import MomentumBadgePreview from "../../components/momentum/MomentumBadgePreview";

const title = "Badge Preview · Momentum";
const description = "Internal preview of Momentum Builder badges.";
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://use.typekit.net/tlh5dan.css" />
  </Fragment>
  <div class="relative z-10 min-h-screen bg-[#060606] pt-28 pb-24 px-4 sm:px-6">
    <div
      class="pointer-events-none fixed inset-0 z-0"
      style="background: radial-gradient(60% 60% at 50% 0%, rgba(249,115,22,0.08) 0%, rgba(0,0,0,0) 70%);"
    />
    <div class="relative z-10 mx-auto max-w-7xl">
      <div class="mb-12 text-center">
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.35em] text-orange-400">
          internal · momentum '26
        </p>
        <h1 class="font-seasons text-5xl text-white sm:text-6xl">Builder Pass · Teams</h1>
        <p class="mt-3 text-sm text-white/50">
          Preview of the four team badges. Each pass is unique per builder (member no., sig
          matrix, star field).
        </p>
      </div>
      <MomentumBadgePreview client:only="react" />
    </div>
  </div>
</Layout>
