---
import Layout from '../layouts/Layout.astro';
import ApplicationForm from '../components/ApplicationForm';
import Polaroid from '../components/Polaroid.astro';
---

<Layout title="Apply - Join Our Incubator">
  <main class="min-h-screen bg-neutral-950 relative overflow-hidden flex items-center justify-center">
  
    <div class="max-w-5xl mx-auto py-12 px-4 sm:px-6 lg:px-8 relative z-0">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-extrabold text-white sm:text-5xl sm:tracking-tight lg:text-6xl">
          Thank you for your interest in joining our <span class="text-orange-500">Incubator</span>
        </h1>
        <p class="mt-5 max-w-xl mx-auto text-xl text-gray-300">
          We will be in touch soon! <span class="font-medium text-white">Applications are now closed</span>, we hope to see you in the future.
        </p>
      </div>
      
      <!-- <ApplicationForm client:load /> -->
    </div>

    <!-- Decorative Polaroids -->
    <Polaroid 
      image="https://dhanush.wtf/media/y8wsq0whok.jpg?file=" 
      rotate="8deg" 
      top="5%" 
      right="5%" 
    />
    <Polaroid 
      image="https://dhanush.wtf/media/lvl3cogtiqg.jpg?file=" 
      rotate="-12deg" 
      top="30%" 
      left="5%" 
    />
    <Polaroid 
      image="https://dhanush.wtf/media/spch2uan9ni.jpg?file=" 
      rotate="15deg" 
      top="60%" 
      right="8%" 
    />
    <Polaroid 
      image="https://dhanush.wtf/media/7ww23hq0p6f.jpg?file=" 
      rotate="-5deg" 
      top="75%" 
      left="12%" 
    />
  </main>
</Layout>

<style>
  :global(body) {
    background-color: #111;
  }
</style> 