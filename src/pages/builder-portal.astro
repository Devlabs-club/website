---
import Layout from '@/layouts/Layout.astro';
import ConversationalShell from '@/components/portal/ConversationalShell';
---

<Layout title="Builder Portal · DevLabs">
  <main class="relative pt-44 pb-24 px-4 md:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="mb-10">
        <p class="text-[#fa7d22] uppercase tracking-[0.2em] text-xs font-semibold">Builder OS</p>
        <h1 class="text-white text-5xl md:text-7xl leading-[0.95] mt-3">
          claim your <span class="font-[Mistrully] italic">proof-of-work</span>
        </h1>
        <p class="text-white/60 mt-5 max-w-3xl text-lg">Attend → Build → Submit → Get feedback → Update availability → Get matched. This is your living DevLabs profile.</p>
      </div>

      <ConversationalShell
        client:load
        title="Builder Claim & Profile Agent"
        subtitle="Hey builder — I can claim your profile, verify projects, and update your availability in one flow."
        options={[
          {
            label: 'Claim Profile',
            action: 'claim_profile',
            placeholder: 'Enter your Builder Profile ID to claim your profile',
          },
          {
            label: 'Update Availability',
            action: 'update_availability',
            placeholder: 'builderId | available(true/false) | hours/week | comp | remote/hybrid/in_person',
          },
        ]}
      />
    </div>
  </main>
</Layout>
