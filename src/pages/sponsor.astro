---
import Layout from "../layouts/Layout.astro";
import CenteredSection from "../components/CenteredSection.astro";
import WrappedText from "../components/text/WrappedText.astro";
import Heading from "../components/text/Heading.astro";
import Paragraph from "../components/text/Paragraph.astro";
import Highlight from "../components/text/Highlight.astro";
import GradientBlob from "../components/GradientBlob.astro";
---

<Layout title="Sponsor Devlabs - Support Student Innovation">
  <!-- Hero Section with Image -->
  <CenteredSection id="hero" className="mb-24">
    <GradientBlob top="" right="" left="0" scale="1.5" />
    <GradientBlob top="60%" left="-15%" right="" scale="1.2" />

    <div
      class="w-2/3 flex flex-col lg:gap-16 md:gap-12 gap-8 items-center text-center md:pt-40 md:pb-32 py-20"
    >
      <!-- Image with dashed border and opacity -->
      <div class="w-full max-w-4xl mx-auto relative">
        <div
          class="w-full h-[450px] md:h-[550px] bg-white/20 rounded-3xl p-2 shadow-2xl overflow-hidden backdrop-blur-sm border-2 border-dashed border-white/30"
        >
          <img
            src="/events/devhack1.jpg"
            alt="Devlabs Event"
            class="w-full h-full object-cover opacity-70 rounded-2xl"
          />
        </div>
      </div>

      <Heading
        >Support the Next Generation of <Highlight>Student Founders</Highlight
        ></Heading
      >
      <Paragraph className="text-lg md:text-xl max-w-3xl mx-auto">
        At Devlabs, we empower student builders through hands-on programs like
        DevHouse, DevHacks, and Build Nights. By sponsoring DevLabs, you're not
        just funding events — you're fueling innovation and backing Arizona's
        next wave of startups.
      </Paragraph>
      <div class="flex flex-col sm:flex-row gap-6 mt-4 mb-8">
        <WrappedText
          size="large"
          className="border-orange-300 text-orange-300 bg-transparent font hover:bg-orange-300 hover:text-black "
          ><a
            href="mailto:people@devlabs.club"
            class="font-bold text-xl md:text-2xl">email us</a
          ></WrappedText
        >
      </div>
    </div>
    <!-- Contact Buttons -->
  </CenteredSection>
</Layout>
