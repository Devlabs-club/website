---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Team from "../components/Team.astro";
import CenteredSection from "../components/CenteredSection.astro";
import Navbar from "../components/Navbar.astro";

import WrappedText from "../components/text/WrappedText.astro";
import Heading from "../components/text/Heading.astro";
import Highlight from "../components/text/Highlight.astro";
import Paragraph from "../components/text/Paragraph.astro";

import ContactForm from "../components/ContactForm.astro";

import GradientBlob from "../components/GradientBlob.astro";
import HeroSection from "../components/HeroSection.astro";
import Polaroid from "../components/Polaroid.astro";

const stats = [
  ["1 year", "in motion"],
  ["500+", "community members"],
  ["15", "club sponsors"],
  ["15", "core organizers"],
  ["170+", "hackers at devhacks'25"],
  ["1", "pioneering mission"],
  ["12", "public events hosted"],
  ["$25,000+", "invested into founders"],
];

const faqs = [
  [
    "what is devlabs?",
    "DevLabs started as ASU's most ambitious club and is now Arizona's answer to Y Combinator. We are a founder-led community and ecosystem, not just another college club. We run a hacker house, a startup incubator, and a builder community to help raise a new generation of Arizona founders.",
  ],
  [
    "what is the devlabs hacker house?",
    "It's a 6-week, high-energy residency for 15 early-stage founders in Phoenix. Founders live, learn, and build side-by-side, culminating in a Demo Day in front of VCs, angels, and ecosystem leaders. Think Y Combinator, but scrappy, local, and all in on Arizona. The next one is from June 20 - August 1, 2025.",
  ],
  [
    "who can join?",
    "We are open to anyone who builds. While we started at ASU, we are not limited to students. We welcome all ambitious builders who want to create world-class products. If you're building, you belong.",
  ],
  [
    "how is devlabs different?",
    "We are community-first and founders-led. This isn't a university program with red tape. We are run by raw builders and tactical mentors, with a culture of execution. We take risks, break things, and learn fast.",
  ],
  [
    "what's the mission?",
    "Our one mission is to grow, serve, and build Arizona's next-generation startup ecosystem. We're here to launch 100+ startups from Phoenix to the world, from dorm rooms to demo days.",
  ],
];
---

<Layout title="DevLabs">
  <Header />
  <HeroSection />

  <div
    id="about"
    class="container mx-auto relative flex flex-col items-center mb-24 border-x border-dashed border-gray-700"
  >
    <GradientBlob top="" right="" left="0" scale="1.5" />
    <Polaroid
      image="https://dhanush.wtf/media/dt6y9pnhy5.jpg?file="
      rotate="8deg"
      top="60%"
      right="5%"
    />
    <Polaroid
      image="https://dhanush.wtf/media/ngpubzgtzsn.jpg?file="
      rotate="-12deg"
      top="10%"
      left="10%"
    />

    <div
      class="w-2/3 flex flex-col lg:gap-16 md:gap-12 gap-8 items-center text-center md:pt-40 md:pb-32 py-20"
    >
      <WrappedText size="normal" className="">our story</WrappedText>
      <Heading
        >born in a dorm room. now <Highlight>building a movement</Highlight
        >.</Heading
      >
      <div class="flex flex-wrap gap-2 justify-center">
        <WrappedText size="large" className="border-orange-300 text-orange-300"
          >hacker house</WrappedText
        >
        <WrappedText size="large" className="border-orange-300 text-orange-300"
          >startup incubator</WrappedText
        >
        <WrappedText size="large" className="border-orange-300 text-orange-300"
          >builder community</WrappedText
        >
      </div>
      <Paragraph
        >Devlabs started as ASU's most ambitious club. Today, we're becoming
        Arizona's answer to Buildspace & Y Combinator — a hacker house where
        world-class products are born. Not limited to students. Open to anyone
        who builds. We're raising a new generation of Arizona founders.</Paragraph
      >
    </div>
  </div>

  <CenteredSection id="stats" className="mb-24">
    <GradientBlob top="-400px" right="-350px" left="" scale="1.5" />
    
    <div class="w-2/3 flex flex-col lg:gap-16 md:gap-12 gap-8 items-center text-center md:py-40 py-20">
      <WrappedText size="normal" className="">our impact</WrappedText>
      <Heading>the numbers speak for <Highlight>themselves</Highlight>.</Heading>
      
      <div class="grid md:grid-cols-4 grid-cols-2 gap-4 w-full">
        {stats.map(([number, label]) => (
          <div class="flex flex-col items-center p-6 border border-dashed border-gray-700 hover:border-orange-500 transition-colors duration-300 group">
            <span class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-orange-500 to-orange-300 bg-clip-text text-transparent transition-colors duration-300">{number}</span>
            <span class="text-sm md:text-base text-gray-400 mt-2 text-center group-hover:text-orange-300 transition-colors duration-300">{label}</span>
          </div>
        ))}
      </div>

      <Paragraph>we're here to launch 100+ startups from Phoenix to the world.</Paragraph>
    </div>
  </CenteredSection>

  <CenteredSection id="mission" className="mb-24">
    <GradientBlob top="-400px" left="-300px" right="" scale="1.5" />
    <Polaroid
      image="https://dhanush.wtf/media/spch2uan9ni.jpg?file="
      rotate="-7deg"
      top="20%"
      right="10%"
    />
    <Polaroid
      image="https://dhanush.wtf/media/7ww23hq0p6f.jpg?file="
      rotate="10deg"
      top="70%"
      left="15%"
    />

    <div
      class="w-2/3 flex flex-col lg:gap-16 md:gap-12 gap-8 items-center text-center md:py-40 py-20"
    >
      <WrappedText size="normal" className="">what we do</WrappedText>
      <Heading
        >we are a community. we're <Highlight
          >Arizona's startup engine</Highlight
        >.</Heading
      >
      <div class="flex flex-col gap-4 items-center">
        <Paragraph>Incubator-style builder cohorts</Paragraph>
        <Paragraph>Mentorship from top-tier founders and VCs</Paragraph>
        <Paragraph>Demo nights. Hackathons. Startup showcases.</Paragraph>
        <Paragraph>Early funding access for promising ideas</Paragraph>
        <Paragraph>We turn raw builders into real founders.</Paragraph>
      </div>
    </div>
  </CenteredSection>

  <!-- <Events /> -->

  <Team
    members={[
      ["dhanush vardhan", "/team/dhanush.jpg", "president"],
      ["soham daga", "/team/soham.jpg", "vice president"],
      ["bhoomi singhani", "/team/bhoomi.jpeg", "vp of operations"], 
      ["chakshu jain", "/team/chakshu.JPG", "vp of finance"],
      ["tanish parsana", "/team/tanish.jpg", "vp of industry"],
      ["adwait more", "/team/adwait.jpg", "marketing director"],
      ["aditya bohra", "/team/aditya.jpg", "marketing officer"],
      ["riya ubhe", "/team/riya.jpg", "marketing officer"],
      ["anay shirolkar", "/team/anay.jpg", "marketing officer"],
      ["dev thakkar", "/team/dev.jpeg", "events officer"],
      ["khushal saini", "/team/khushal.jpeg", "videographer"],
      ["sreeram sreedhar", "/team/sreeram.jpg", "photographer"],
      ["debo bannerjee", "/team/debo.jpeg", "video editor"],
      ["yuvam bhargav", "/team/yuvam.jpeg", "finance officer"],
      ["aryan keluskar", "/team/aryan.png", "industry officer"],
      ["pranay athipathala", "/team/pranay.jpg", "industry officer"],
    ]}
  />

  <CenteredSection id="vision" className="mb-24">
    <GradientBlob top="-400px" right="-350px" left="" scale="1.5" />
    <Polaroid
      image="https://dhanush.wtf/media/udqhwdp2kcn.jpg?file="
      rotate="-15deg"
      top="25%"
      left="10%"
    />
    <Polaroid
      image="https://dhanush.wtf/media/uzp4y1ct1g.jpg?file="
      rotate="6deg"
      top="65%"
      right="15%"
    />

    <div
      class="w-2/3 flex flex-col lg:gap-16 md:gap-12 gap-8 items-center text-center md:py-40 py-20"
    >
      <Heading
        >We are building the <Highlight>launchpad</Highlight> for Arizona's next
        <Highlight> 100 startups.</Highlight></Heading
      >
      <div class="flex flex-col gap-6 items-center">
        <WrappedText size="normal" className="">our vision</WrappedText>

        <div class="flex flex-col gap-4 items-center">
          <Paragraph
            >Build Arizona's first full-time incubator for real builders</Paragraph
          >
          <Paragraph>Launch a hacker house in PHX</Paragraph>
          <Paragraph
            >Fund and support 50+ startups in the next 3 years</Paragraph
          >
        </div>
        <Paragraph>Phoenix deserves this. We're building it.</Paragraph>
      </div>
    </div>
  </CenteredSection>

  <CenteredSection id="faq" className="mb-24">
    <GradientBlob top="-400px" left="-350px" right="" scale="1.5" />

    <div
      class="w-2/3 flex flex-col lg:gap-16 md:gap-12 gap-8 items-center text-center md:py-40 py-20"
    >
      <WrappedText size="normal" className="">FAQ</WrappedText>
      <Heading>have questions? we have <Highlight>answers</Highlight>.</Heading>
      <div class="w-full flex flex-col gap-4">
        {
          faqs.map(([question, answer]) => (
            <details class="group faq-item border-b border-dashed border-gray-700 py-4 last:border-b-0">
              <summary class="flex items-center justify-between cursor-pointer list-none">
                <h3 class="text-lg md:text-xl font-medium text-gray-200 group-hover:text-white text-left">
                  {question}
                </h3>
                <div class="relative flex items-center justify-center w-4 h-4 ml-4 flex-shrink-0">
                  <div class="w-full h-0.5 bg-gray-400 rounded-full" />
                  <div class="absolute w-full h-0.5 bg-gray-400 rounded-full transition-transform duration-300 rotate-90 group-open:scale-x-0" />
                </div>
              </summary>
              <div class="mt-4 text-left">
                <p class="text-gray-400 md:text-lg text-base font-normal leading-relaxed">
                  {answer}
                </p>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </CenteredSection>

  <CenteredSection id="contact" className="mb-24">
    <GradientBlob top="-400px" right="-350px" left="" scale="1.5" />

    <div
      class="w-2/3 flex flex-col lg:gap-16 md:gap-12 gap-8 items-center text-center md:py-40 py-20"
    >
      <WrappedText size="normal" className="">want to talk to us?</WrappedText>
      <Heading><Highlight>reach out</Highlight> and say hi.</Heading>
      <ContactForm />
    </div>
  </CenteredSection>

  <Navbar />
</Layout>

<script>
  const detailsElements =
    document.querySelectorAll<HTMLDetailsElement>(".faq-item");

  detailsElements.forEach((targetDetail) => {
    targetDetail.addEventListener("toggle", () => {
      if (targetDetail.open) {
        detailsElements.forEach((detail) => {
          if (detail !== targetDetail) {
            detail.open = false;
          }
        });
      }
    });
  });
</script>
