    <CenteredSection id="contact" className="mb-24">
        <GradientBlob top="-400px" right="-350px" left="" scale="1.5" />

        <div class="w-2/3 flex flex-col lg:gap-16 md:gap-12 gap-8 items-center text-center md:py-40 py-20">
            <WrappedText size="normal" className=''>want to talk to us?</WrappedText>
            <Heading><Highlight>reach out</Highlight> and say hi.</Heading>
            <ContactForm />
        </div>
    </CenteredSection>

</Layout>

<style>
  /* Ensure polaroids in about section are below text but above background */
  #about .polaroid {
    z-index: 5;
  }
  
  #about > div {
    z-index: 20;
  }
</style>

