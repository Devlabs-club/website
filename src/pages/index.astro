---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Main from "../components/Main.astro";
import Events from "../components/Events.astro";
import Team from "../components/Team.astro";
import CenteredSection from "../components/CenteredSection.astro";
import Navbar from "../components/Navbar.astro";

import WrappedText from "../components/text/WrappedText.astro";
import Heading from "../components/text/Heading.astro";
import HeadingBig from "../components/text/HeadingBig.astro";
import Highlight from "../components/text/Highlight.astro";
import Paragraph from "../components/text/Paragraph.astro";

import LinkButton from "../components/LinkButton.astro";
import Scroll from "../components/Scroll.astro";
import Cards from "../components/Cards.astro";
import ContactForm from "../components/ContactForm.astro";

import GradientBlob from "../components/GradientBlob.astro";
import HeroSection from "../components/HeroSection.astro";
import Polaroid from "../components/Polaroid.astro";
---

<Layout title="DevLabs">
  <Header />
  <HeroSection />

  <div
    id="about"
    class="container mx-auto relative flex flex-col items-center mb-24 border-x border-dashed border-gray-700"
  >
    <GradientBlob top="" right="" left="0" scale="1.5" />
    <Polaroid
      image="https://dhanush.wtf/media/dt6y9pnhy5.jpg?file="
      rotate="8deg"
      top="60%"
      right="5%"
    />
    <Polaroid
      image="https://dhanush.wtf/media/ngpubzgtzsn.jpg?file="
      rotate="-12deg"
      top="10%"
      left="10%"
    />

    <div
      class="w-2/3 flex flex-col lg:gap-16 md:gap-12 gap-8 items-center text-center md:pt-40 md:pb-32 py-20"
    >
      <WrappedText size="normal" className="">our story</WrappedText>
      <Heading
        >born in a dorm room. now <Highlight>building a movement</Highlight
        >.</Heading
      >
      <div class="flex flex-wrap gap-2 justify-center">
        <WrappedText size="large" className="border-orange-300 text-orange-300"
          >hacker house</WrappedText
        >
        <WrappedText size="large" className="border-orange-300 text-orange-300"
          >startup incubator</WrappedText
        >
        <WrappedText size="large" className="border-orange-300 text-orange-300"
          >builder community</WrappedText
        >
      </div>
      <Paragraph
        >Devlabs started as ASU's most ambitious club. Today, we're becoming
        Arizona's answer to Buildspace & Y Combinator — a hacker house where
        world-class products are born. Not limited to students. Open to anyone
        who builds. We're raising a new generation of Arizona founders.</Paragraph
      >
    </div>
  </div>

  <CenteredSection id="mission" className="mb-24">
    <GradientBlob top="-400px" left="-300px" right="" scale="1.5" />
    <Polaroid
      image="https://dhanush.wtf/media/spch2uan9ni.jpg?file="
      rotate="-7deg"
      top="20%"
      right="10%"
    />
    <Polaroid
      image="https://dhanush.wtf/media/7ww23hq0p6f.jpg?file="
      rotate="10deg"
      top="70%"
      left="15%"
    />

    <div
      class="w-2/3 flex flex-col lg:gap-16 md:gap-12 gap-8 items-center text-center md:py-40 py-20"
    >
      <WrappedText size="normal" className="">what we do</WrappedText>
      <Heading
        >we are a community. we're <Highlight
          >Arizona's startup engine</Highlight
        >.</Heading
      >
      <div class="flex flex-col gap-4 items-center">
        <Paragraph>Incubator-style builder cohorts</Paragraph>
        <Paragraph>Mentorship from top-tier founders and VCs</Paragraph>
        <Paragraph>Demo nights. Hackathons. Startup showcases.</Paragraph>
        <Paragraph>Early funding access for promising ideas</Paragraph>
        <Paragraph>We turn raw builders into real founders.</Paragraph>
      </div>
    </div>
  </CenteredSection>

  <!-- <Events /> -->

  <Team
    members={[
      ["dhanush vardhan", "/team/dhanush.jpg", "president"],
      ["soham daga", "/team/soham.jpg", "vice president"],
      ["bhoomi singhani", "/team/bhoomi.jpeg", "vp of operations"],
      ["chakshu jain", "/team/chakshu.JPG", "vp of finance"],
      ["aryan keluskar", "/team/aryan.png", "industry director"],
      ["adwait more", "/team/adwait.jpg", "marketing director"],
      ["aditya bohra", "/team/aditya.jpg", "marketing officer"],
      ["riya ubhe", "/team/riya.jpg", "marketing officer"],
      ["anay shirolkar", "/team/anay.jpg", "marketing officer"],
      ["dev thakkar", "/team/dev.jpeg", "events officer"],
      ["khushal saini", "/team/khushal.jpeg", "videographer"],
      ["sreeram sreedhar", "/team/sreeram.jpg", "photographer"],
      ["debo bannerjee", "/team/debo.jpeg", "video editor"],
      ["tanish parsana", "/team/tanish.jpg", "industry officer"],
      ["yuvam bhargav", "/team/yuvam.jpeg", "industry officer"],
    ]}
  />

  <CenteredSection id="vision" className="mb-24">
    <GradientBlob top="-400px" right="-350px" left="" scale="1.5" />
    <Polaroid
      image="https://dhanush.wtf/media/udqhwdp2kcn.jpg?file="
      rotate="-15deg"
      top="25%"
      left="10%"
    />
    <Polaroid
      image="https://dhanush.wtf/media/uzp4y1ct1g.jpg?file="
      rotate="6deg"
      top="65%"
      right="15%"
    />

    <div
      class="w-2/3 flex flex-col lg:gap-16 md:gap-12 gap-8 items-center text-center md:py-40 py-20"
    >
      <Heading
        >We are building the <Highlight>launchpad</Highlight> for Arizona's next
        <Highlight> 100 startups.</Highlight></Heading
      >
      <div class="flex flex-col gap-6 items-center">
        <WrappedText size="normal" className="">our vision</WrappedText>

        <div class="flex flex-col gap-4 items-center">
          <Paragraph
            >Build Arizona's first full-time incubator for real builders</Paragraph
          >
          <Paragraph>Launch a hacker house in PHX</Paragraph>
          <Paragraph
            >Fund and support 50+ startups in the next 3 years</Paragraph
          >
        </div>
        <Paragraph>Phoenix deserves this. We're building it.</Paragraph>
      </div>
    </div>
  </CenteredSection>

  <CenteredSection id="contact" className="mb-24">
    <GradientBlob top="-400px" right="-350px" left="" scale="1.5" />

    <div
      class="w-2/3 flex flex-col lg:gap-16 md:gap-12 gap-8 items-center text-center md:py-40 py-20"
    >
      <WrappedText size="normal" className="">want to talk to us?</WrappedText>
      <Heading><Highlight>reach out</Highlight> and say hi.</Heading>
      <ContactForm />
    </div>
  </CenteredSection>

  <Navbar />
</Layout>
