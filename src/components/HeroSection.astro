---
import CompanyMarquee from "./CompanyMarquee.astro";
---

<section
  class="relative w-screen h-screen overflow-hidden"
  data-parallax-section
>
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <video
      id="hero-video"
      class="w-full h-full object-cover"
      src="/hero.mov"
      autoplay
      muted
      playsinline
      preload="auto"></video>

    <!-- Heavy top fade: black -> transparent -->
    <div
      class="absolute inset-x-0 top-0 h-[45%] bg-gradient-to-b from-black via-black/70 to-transparent pointer-events-none"
    >
    </div>

    <!-- Heavy bottom fade: transparent -> black -->
    <div
      class="absolute inset-x-0 bottom-0 h-[55%] bg-gradient-to-t from-black via-black/70 to-transparent pointer-events-none"
    >
    </div>

    <!-- Heavy left fade: black -> transparent -->
    <div
      class="absolute inset-y-0 left-0 w-[22%] bg-gradient-to-r from-black via-black/70 to-transparent pointer-events-none"
    >
    </div>

    <!-- Heavy right fade: black -> transparent -->
    <div
      class="absolute inset-y-0 right-0 w-[22%] bg-gradient-to-l from-black via-black/70 to-transparent pointer-events-none"
    >
    </div>
  </div>

  <script is:inline>
    (() => {
      const video = document.getElementById("hero-video");
      if (!(video instanceof HTMLVideoElement)) return;

      // 0.5x speed
      video.playbackRate = 0.5;

      // Ensure playbackRate is applied after metadata loads too
      video.addEventListener("loadedmetadata", () => {
        video.playbackRate = 0.5;
      });

      // Pause on last frame when video ends
      video.addEventListener("ended", () => {
        const d = Number.isFinite(video.duration) ? video.duration : 0;
        // Seek a tiny bit before the end to reliably show the last frame
        video.currentTime = Math.max(0, d - 0.05);
        video.pause();
      });

      // Stop playing as soon as the user scrolls down
      const onScroll = () => {
        if (window.scrollY > 0 && !video.paused) video.pause();
      };
      window.addEventListener("scroll", onScroll, { passive: true });
    })();
  </script>

  <!-- Foreground layout: content + marquee pinned bottom -->
  <div class="relative h-full w-full flex flex-col">
    <!-- Content Container -->
    <div
      class="w-full mx-auto px-4 sm:px-6 lg:px-8 flex-1 flex flex-col justify-end pt-32 pb-10"
    >
      <!-- Main Heading -->
      <div class="flex flex-col items-start w-full max-w-6xl mb-12 pl-4">
        <h1
          class="text-6xl md:text-8xl lg:text-9xl font-medium text-white tracking-tight leading-none mb-2"
        >
          Go Big or
        </h1>
        <h1
          class="text-6xl md:text-8xl lg:text-9xl font-medium text-transparent tracking-tight leading-none outline-text"
        >
          Get Hired
        </h1>
      </div>

      <!-- Action Boxes -->
      <div
        class="flex flex-col md:flex-row justify-between gap-6 md:gap-0 pl-4"
      >
        <!-- Box 1: Description -->
        <div
          class="md:w-[32%] border border-white/40 p-6 flex items-center bg-black/20 backdrop-blur-sm h-24"
        >
          <p class="text-white text-lg font-light leading-tight">
            The community where we launch founders
          </p>
        </div>

        <!-- Box 2: Events -->
        <a
          href="/events"
          class="md:w-[32%] border border-white/40 p-6 flex items-center justify-between group hover:bg-white/10 transition-colors bg-black/20 backdrop-blur-sm cursor-pointer h-24"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-10 w-10 text-white transform group-hover:translate-x-1 transition-transform"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
          <span
            class="bg-white text-black px-5 py-2.5 text-sm font-bold rounded-sm"
          >
            check out our events
          </span>
        </a>

        <!-- Box 3: Talent -->
        <a
          href="/clientform"
          class="md:w-[32%] border border-white/40 p-6 flex items-center justify-between group hover:bg-white/10 transition-colors bg-black/20 backdrop-blur-sm cursor-pointer h-24"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-10 w-10 text-white transform group-hover:translate-x-1 transition-transform"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
          <span
            class="bg-white text-black px-5 py-2.5 text-sm font-bold rounded-sm"
          >
            hire the best talent
          </span>
        </a>
      </div>
    </div>

    <!-- Trusted By Section (pinned to bottom of hero) -->
    <div class="w-full relative z-30 mt-auto">
      <CompanyMarquee />
    </div>
  </div>
</section>

<style>
  .outline-text {
    -webkit-text-stroke: 1px white;
    color: transparent;
  }

  /* Responsive adjustments for outline text stroke width */
  @media (min-width: 768px) {
    .outline-text {
      -webkit-text-stroke: 2px white;
    }
  }
</style>
