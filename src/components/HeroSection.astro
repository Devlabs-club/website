---
import CompanyMarquee from "./CompanyMarquee.astro";
import { Icon } from "free-astro-components";
---

<section
  class="hero-section relative w-screen min-h-screen overflow-hidden flex flex-col items-center py-20 px-4"
  data-parallax-section
>
  <!-- Dark background -->
  <div class="absolute inset-0 z-0" aria-hidden="true"></div>

  <!-- Star left: large, partially off-screen -->
  <div
    class="hero-star-left absolute z-10 w-[min(90vw,520px)] h-auto -translate-x-[45%] top-[18%] left-0 pointer-events-none"
    aria-hidden="true"
  >
    <img
      src="/star.svg"
      alt=""
      class="w-full h-auto block"
      width="487"
      height="485"
    />
  </div>

  <!-- Star right: visible top-right -->
  <div
    class="hero-star-right absolute z-10 w-16 h-16 md:w-20 md:h-20 top-[12%] right-[6%] pointer-events-none"
    aria-hidden="true"
  >
    <img
      src="/star.svg"
      alt=""
      class="w-full h-auto block"
      width="487"
      height="485"
    />
  </div>

  <!-- Content: headline at 35vh from top, rest flows below -->
  <div
    class="relative z-20 w-full max-w-5xl mx-auto flex flex-col items-center text-center"
  >
    <!-- Headline: 35vh from top, fixed position from viewport top -->
    <h1
      class="hero-headline text-white mb-8 md:mb-10 text-center shrink-0 mt-[15vh]"
    >
      <span class="block">
        <span
          class="hero-headline-intro font-manrope text-xl md:text-2xl lg:text-3xl font-normal text-white"
          >we help
        </span>
        <span
          class="hero-headline-emphasis font-serif italic text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl text-white leading-tight"
          >builders</span
        >
      </span>
      <span class="block">
        <span
          class="hero-headline-emphasis hero-underline font-serif italic text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl text-white leading-tight"
          >go big
        </span>
        <span
          class="hero-headline-intro font-manrope text-xl md:text-2xl lg:text-3xl font-normal text-white"
          >or
        </span>
        <span
          class="hero-headline-emphasis hero-underline font-serif italic text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl text-white leading-tight"
          >get hired</span
        >
      </span>
    </h1>

    <!-- Everything below headline: logo, stats, marquee -->
    <div class="flex flex-col items-center justify-start w-full shrink-0">
      <!-- Center logo -->
      <div class="hero-logo w-16 h-16 mb-10 flex-shrink-0">
        <img
          src="/logo.png"
          alt="DevLabs"
          class="w-full h-full object-contain"
          width="112"
          height="112"
        />
      </div>

      <div
        class="grid grid-cols-2 justify-center gap-8 md:gap-16 lg:gap-24 max-w-4xl mb-10"
      >
        <a
          href="/api/auth/oauth/login"
          class="group relative inline-block px-8 py-4
               bg-gradient-to-br from-white/10 via-white/5 to-transparent
               backdrop-blur-lg border border-white/20
               text-white/80 font-medium text-lg rounded-full
               transition-all duration-500 hover:scale-105
               shadow-[0_8px_32px_rgba(255,255,255,0.1)]
               hover:shadow-[0_16px_48px_rgba(255,255,255,0.2)]
               hover:border-white/30 hover:bg-gradient-to-br hover:from-white/20 hover:via-white/10 hover:to-white/5
               before:absolute before:inset-0 before:rounded-xl before:bg-gradient-to-r before:from-white/10 before:to-transparent before:opacity-0 hover:before:opacity-100 before:transition-opacity before:duration-500"
        >
          <span class="tracking-wide pl-2"> join now </span>

          <!-- right action circle -->
        </a>

        <a
          href="/find-talent"
          class="group relative inline-block px-8 py-4
               bg-gradient-to-br from-white/10 via-white/5 to-transparent
               backdrop-blur-lg border border-white/20
               text-white/80 font-medium text-lg rounded-full
               transition-all duration-500 hover:scale-105
               shadow-[0_8px_32px_rgba(255,255,255,0.1)]
               hover:shadow-[0_16px_48px_rgba(255,255,255,0.2)]
               hover:border-white/30 hover:bg-gradient-to-br hover:from-white/20 hover:via-white/10 hover:to-white/5
               before:absolute before:inset-0 before:rounded-xl before:bg-gradient-to-r before:from-white/10 before:to-transparent before:opacity-0 hover:before:opacity-100 before:transition-opacity before:duration-500"
        >
          <span class="relative z-10 drop-shadow-sm">meet our talent</span>
          <div
            class="absolute inset-0.5 rounded-xl bg-gradient-to-br from-white/5 to-transparent opacity-60"
          >
          </div>
        </a>
      </div>

      <!-- Stats -->
      <div
        class="hero-stats flex flex-wrap justify-center gap-8 lg:gap-12 max-w-4xl opacity-80 mt-10"
      >
        <div class="flex flex-col items-start w-fit">
          <span
            class="font-manrope text-2xl md:text-6xl font-semibold text-white"
            >500+</span
          >
          <span class="font-manrope text-sm md:text-base text-white/90 mt-0.5"
            >builders</span
          >
        </div>

        <div class="hidden md:block w-px h-12 bg-white/20 self-center"></div>

        <div class="flex flex-col items-start w-fit">
          <span
            class="font-manrope text-2xl md:text-6xl font-semibold text-white"
            >50+</span
          >
          <span class="font-manrope text-sm md:text-base text-white/90 mt-0.5"
            >startups built</span
          >
        </div>

        <div class="hidden md:block w-px h-12 bg-white/20 self-center"></div>

        <div class="flex flex-col items-start w-fit">
          <span
            class="font-manrope text-2xl md:text-6xl font-semibold text-white"
            >120k+</span
          >
          <span class="font-manrope text-sm md:text-base text-white/90 mt-0.5"
            >raised</span
          >
        </div>

        <div class="hidden md:block w-px h-12 bg-white/20 self-center"></div>

        <div class="flex flex-col items-start w-fit">
          <span
            class="font-manrope text-2xl md:text-6xl font-semibold text-white"
            >10+</span
          >
          <span class="font-manrope text-sm md:text-base text-white/90 mt-0.5"
            >events</span
          >
        </div>
      </div>

      <!-- Company marquee -->
      <div class="hero-marquee w-full mt-14 md:mt-20 mb-14 md:mb-20">
        <CompanyMarquee />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-headline {
    font-family: Manrope, sans-serif;
  }

  .hero-headline-emphasis {
    font-family: "Times New Roman", Times, Georgia, serif;
    font-style: italic;
  }

  .hero-underline {
    position: relative;
    display: inline-block;
  }

  .hero-underline::after {
    content: "";
    position: absolute;
    left: 0.1em;
    right: 0.1em;
    bottom: 0.03em;
    height: 0.24em;
    background-color: #fa7d22;
    opacity: 0.8;
    z-index: -1;
    transform: rotate(-3.5deg);
    transform-origin: left center;
  }

  .font-manrope {
    font-family: Manrope, sans-serif;
  }
</style>
