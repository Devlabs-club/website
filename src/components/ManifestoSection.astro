---
---

<section
  class="w-full bg-transparent relative overflow-hidden py-24"
  data-parallax-section
  data-parallax-depth="0.04"
>
  <!-- Theme background overlay (soft, no hard edges) -->
  <div
    aria-hidden="true"
    class="absolute inset-0 z-0 "
  ></div>

  <!-- Full-width layout with only side padding "margin" -->
  <div class="w-full px-4 sm:px-6 lg:px-12 relative z-10 mt-10">
    <div class="manifesto-frame relative w-full border border-white/15">
      <!-- Top segmented bar -->
      <div class="absolute top-0 left-0 right-0 h-12 border-b border-white/15 flex">
        <div class="w-[28%] bg-gradient-to-r from-orange-500/25 to-white/5"></div>
        <div class="w-[26%] bg-gradient-to-r from-white/5 to-orange-400/15"></div>
        <div class="flex-1 bg-gradient-to-r from-white/5 via-white/10 to-orange-500/20"></div>
        <div class="w-[12%] bg-gradient-to-r from-orange-500/20 to-white/5"></div>

        <div class="absolute inset-0 flex items-center justify-between px-6 text-[10px] tracking-[0.22em] uppercase text-white/70">
          <span class="hidden sm:inline">The biggest misconceptions</span>
          <span class="text-white/70">The printing press</span>
          <span class="hidden sm:inline">Each of us creates</span>
        </div>
      </div>

      <!-- Bottom segmented bar -->
      <div class="absolute bottom-0 left-0 right-0 h-12 border-t border-white/15 flex">
        <div class="w-[33%] bg-gradient-to-r from-orange-500/22 to-transparent"></div>
        <div class="w-[34%] bg-gradient-to-r from-transparent via-black/45 to-transparent"></div>
        <div class="flex-1 bg-gradient-to-r from-transparent to-orange-500/18"></div>

        <div class="absolute inset-0 flex items-center justify-between px-6 text-[10px] tracking-[0.22em] uppercase text-white/75">
          <span class="hidden sm:inline">Place for creators</span>
          <span class="text-white/65">The printing press</span>
          <span class="hidden sm:inline">New era of cooperation</span>
        </div>
      </div>

      <!-- Side rails -->
      <div class="absolute left-0 top-12 bottom-12 w-12 border-r border-white/15">
        <div class="h-full bg-gradient-to-b from-orange-500/25 via-white/5 to-transparent"></div>
        <div class="absolute inset-0 flex items-center justify-center px-1">
          <span class="manifesto-vert text-[10px] tracking-[0.22em] uppercase text-white/70">
            The biggest misconceptions
          </span>
        </div>
      </div>

      <div class="absolute right-0 top-12 bottom-12 w-12 border-l border-white/15">
        <div class="h-full bg-gradient-to-b from-white/10 via-white/5 to-orange-500/10"></div>
        <div class="absolute inset-0 flex items-center justify-center px-1">
          <span class="manifesto-vert text-[10px] tracking-[0.22em] uppercase text-white/70">
            New world
          </span>
        </div>
      </div>

      <!-- Inner panel -->
      <div class="px-6 sm:px-12 py-10 sm:py-14">
        <div class="relative bg-black/90 border border-white/15">
          <div class="absolute inset-x-0 top-0 h-px bg-white/15"></div>
          <div class="absolute inset-x-0 bottom-0 h-px bg-white/15"></div>

          <div class="px-6 sm:px-14 py-16 sm:py-20">
            <p class="text-center text-white/90 text-xl sm:text-2xl md:text-3xl leading-relaxed font-medium">
              <!-- We believe the best way to learn is to build. This is a place to build, ship,
              repeat — to take risks early, fail fast, learn faster, and turn ideas into real companies.
              DevLabs is for builders who show up, do the work, and keep going when it gets hard. -->
            </p>
          </div>

          <!-- <div class="absolute right-6 bottom-6 text-orange-200/90 text-3xl sm:text-4xl font-semibold">
            1
          </div> -->
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .manifesto-vert {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    white-space: nowrap;
    text-align: center;
  }

  .manifesto-frame {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06),
      0 30px 120px rgba(0, 0, 0, 0.65),
      0 0 80px rgba(249, 115, 22, 0.08);
  }
</style>

