---
// Devlabs Collage Component - Built with Tailwind CSS
---

<div class="w-full max-w-4xl mx-auto relative z-10">
  <!-- White rounded border frame -->
  <div
    class="flex flex-col justify-end w-full h-[500px] md:h-[400px] sm:h-[300px] bg-white/40 rounded-3xl p-2 shadow-2xl overflow-hidden backdrop-blur-sm"
  >
    <!-- Single background image with tint -->
    <div class="absolute inset-2 rounded-2xl overflow-hidden bg-[#151413]">
      <img
        src="/events/DevHacks3.jpg"
        alt="Devlabs Event"
        class="w-full h-full object-cover brightness-75 contrast-110 sepia-[0.3] saturate-150 hue-rotate-15"
      />
    </div>

    <!-- Main DEVLABS text touching bottom border -->
    <div
      class="absolute bottom-[-20px] left-0 right-0 z-20 flex items-end justify-center"
    >
      <h1
        class="text-[clamp(2rem,12vw,15rem)] md:text-[clamp(4rem,16vw,18rem)] font-black text-orange-500 opacity-50 tracking-tighter leading-none whitespace-nowrap"
      >
        DEVLABS
      </h1>
    </div>
  </div>
</div>
