---
// NewFooter.astro
// Replacement for the existing footer
---

<footer
  class="footer-below-cta w-full bg-transparent text-white pt-24 pb-10 overflow-hidden relative font-manrope z-10"
>
  <!-- Content Container -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div
      class="flex flex-col md:flex-row justify-between items-start mb-16 md:mb-24"
    >
      <!-- Left Column -->
      <div class="flex flex-col gap-6 md:gap-8">
        <!-- Logo Section -->
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-3">
            <img src="/logo.png" alt="Devlabs Logo" class="h-8 w-auto" />
            <span class="text-2xl font-bold tracking-tight">devlabs</span>
          </div>
          <p class="text-gray-400 text-lg max-w-xs leading-relaxed font-light">
            a home for ambitious inventors, builders, and creatives.
          </p>
        </div>

        <!-- Social Icons -->
        <div class="flex gap-6 items-center mt-2">
          <!-- X (Twitter) -->
          <a
            href="https://twitter.com/devlabs_club"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white hover:text-gray-300 transition-colors"
          >
            <svg
              class="w-6 h-6"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a
            href="https://www.linkedin.com/company/devlabsclub/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white hover:text-gray-300 transition-colors"
          >
            <svg
              class="w-6 h-6"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                clip-rule="evenodd"></path>
            </svg>
          </a>
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/devlabs.asu/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white hover:text-gray-300 transition-colors"
          >
            <svg
              class="w-6 h-6"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772 4.902 4.902 0 011.772-1.153c.636-.247 1.363-.416 2.427-.465 1.067-.047 1.407-.06 4.123-.06h.08zm-1.634 9.256c.844 0 1.547.691 1.547 1.543 0 .851-.691 1.543-1.547 1.543-.844 0-1.547-.691-1.547-1.543 0-.852.691-1.543 1.547-1.543zm6.547-4.13a1.055 1.055 0 100 2.11 1.055 1.055 0 000-2.11zm-5.631 3.42c-2.11 0-3.812 1.703-3.812 3.812s1.703 3.812 3.812 3.812 3.812-1.703 3.812-3.812-1.703-3.812-3.812-3.812z"
                clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right Column (Navigation) -->
      <div class="flex flex-col gap-3 text-left md:text-right mt-12 md:mt-0">
        <a
          href="/"
          class="text-gray-300 hover:text-white transition-colors text-lg font-light"
          >main</a
        >
        <a
          href="/#about"
          class="text-gray-300 hover:text-white transition-colors text-lg font-light"
          >about us</a
        >
        <a
          href="/dashboard"
          class="text-gray-300 hover:text-white transition-colors text-lg font-light"
          >join our newsletter</a
        >

        <a
          href="/sponsor"
          class="text-gray-300 hover:text-white transition-colors text-lg font-light"
          >sponsor us</a
        >
        <a
          href="/mailto:people@devlabs.club"
          class="text-gray-300 hover:text-white transition-colors text-lg font-light"
          >contact us</a
        >
      </div>
    </div>
    <!-- Big Clipped Text - Full Width -->
    <div class="w-full flex justify-center items-end mt-4 relative z-0">
      <h1
        class="w-full text-[18vw] md:text-[22vw] leading-[0.7] font-bold tracking-tighter text-center clipped-text select-none"
      >
        devlabs
      </h1>
    </div>

    <!-- Copyright (Mobile) -->
    <div class="block md:hidden text-center text-gray-500 text-sm pb-8">
      © 2026 - made with love and care for viewers like you
    </div>
  </div>

  <style>
    .clipped-text {
      font-family: "Times New Roman", Times, serif;
      font-style: italic;
      background-image: url("/join_now.png");
      background-size: cover;
      background-position: center;
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      width: 100%;
    }
  </style>
</footer>
