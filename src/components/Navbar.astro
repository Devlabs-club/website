---
import AuthControlsAstro from "./AuthControlsAstro.astro";
---

<nav
  class="fixed top-4 left-1/2 transform -translate-x-1/2 z-50 w-3/4 lg:w-3/4 md:w-11/12 sm:w-11/12"
>
  <div
    class="flex items-center justify-between px-8 py-4 rounded-full border border-white/20 bg-white/10 backdrop-blur-lg backdrop-filter shadow-lg shadow-black/10"
  >
    <!-- Logo section -->
    <div class="flex items-center gap-4 mr-8">
      <a href="/"
        ><img src="/logo.svg" alt="devlabs-logo" class="h-10 w-10" /></a
      >
    </div>

    <!-- Desktop Navigation links -->
    <div class="hidden md:flex items-center gap-6 relative">
      <!-- Orange highlight container (initially hidden) -->
      <div
        id="active-highlight"
        class="absolute bg-gradient-to-r from-orange-500 to-orange-400 rounded-full h-8 transition-all duration-300 ease-out opacity-0 pointer-events-none"
        style="transform: rotate(-2deg);"
      >
      </div>

      <a
        href="/"
        class="nav-link relative z-10 text-white/80 hover:text-white transition-colors duration-200 ease-in-out text-sm font-medium px-3 py-1"
        data-section="story">story</a
      >
      <a
        href="/register"
        id="join-us-link"
        class="nav-link relative z-10 text-white/80 hover:text-white transition-colors duration-200 ease-in-out text-sm font-medium px-3 py-1"
        data-section="join-us">join us</a
      >
      <a
        href="/events"
        class="nav-link relative z-10 text-white/80 hover:text-white transition-colors duration-200 ease-in-out text-sm font-medium px-3 py-1"
        data-section="events">events</a
      >
      <a
        href="/sponsor"
        class="nav-link relative z-10 text-white/80 hover:text-white transition-colors duration-200 ease-in-out text-sm font-medium px-3 py-1"
        data-section="sponsor">sponsor</a
      >
      <a
        href="/find-talent"
        class="nav-link relative z-10 text-white/80 hover:text-white transition-colors duration-200 ease-in-out text-sm font-medium px-3 py-1"
        data-section="find-talent">find talent</a
      >
    </div>

    <!-- Desktop Social links -->
    <div class="hidden md:flex items-center gap-3">
      <a
        href="mailto:people@devlabs.club"
        class="transition-transform duration-200 ease-in-out hover:scale-110"
      >
        <img
          class="w-5 h-5 opacity-70 hover:opacity-100 transition-opacity duration-200 ease-in-out"
          src="/socials/gmail.svg"
          alt="email"
        />
      </a>
      <a
        href="https://www.instagram.com/devlabs.asu/"
        class="transition-transform duration-200 ease-in-out hover:scale-110"
      >
        <img
          class="w-5 h-5 opacity-70 hover:opacity-100 transition-opacity duration-200 ease-in-out"
          src="/socials/instagram.svg"
          alt="insta"
        />
      </a>
      <a
        href="https://discord.gg/4XPKg2nWcj"
        class="transition-transform duration-200 ease-in-out hover:scale-110"
      >
        <img
          class="w-5 h-5 opacity-70 hover:opacity-100 transition-opacity duration-200 ease-in-out"
          src="/socials/discord.svg"
          alt="discord"
        />
      </a>
    </div>
    <!-- Mobile menu button -->

    <button
      id="mobile-menu-btn"
      class="md:hidden flex items-center justify-center w-8 h-8 text-white hover:text-orange-400 transition-colors duration-200"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile menu (hidden by default) -->
  <div
    id="mobile-menu"
    class="hidden md:hidden mt-4 rounded-2xl border border-white/20 bg-white/10 backdrop-blur-lg backdrop-filter shadow-lg shadow-black/10 overflow-hidden transform origin-top transition-all duration-300 ease-out scale-y-0 opacity-0"
  >
    <div class="px-6 py-4 space-y-4">
      <!-- Mobile Navigation links -->
      <div class="space-y-3">
        <a
          href="/"
          class="block text-white/80 hover:text-white transition-colors duration-200 ease-in-out text-sm font-medium py-2 px-3 rounded-lg hover:bg-white/10"
          data-section="story">story</a
        >
        <a
          href="/register"
          id="join-us-link-mobile"
          class="block text-white/80 hover:text-white transition-colors duration-200 ease-in-out text-sm font-medium py-2 px-3 rounded-lg hover:bg-white/10"
          data-section="join-us">join us</a
        >
        <a
          href="/events"
          class="block text-white/80 hover:text-white transition-colors duration-200 ease-in-out text-sm font-medium py-2 px-3 rounded-lg hover:bg-white/10"
          data-section="events">events</a
        >
        <a
          href="/sponsor"
          class="block text-white/80 hover:text-white transition-colors duration-200 ease-in-out text-sm font-medium py-2 px-3 rounded-lg hover:bg-white/10"
          data-section="sponsor">sponsor</a
        >
        <a
          href="/find-talent"
          class="block text-white/80 hover:text-white transition-colors duration-200 ease-in-out text-sm font-medium py-2 px-3 rounded-lg hover:bg-white/10"
          data-section="find-talent">find talent</a
        >
      </div>

      <!-- Mobile Social links -->
      <div class="flex items-center justify-center gap-6 pt-2">
        <a
          href="mailto:people@devlabs.club"
          class="transition-transform duration-200 ease-in-out hover:scale-110"
        >
          <img
            class="w-6 h-6 opacity-70 hover:opacity-100 transition-opacity duration-200 ease-in-out"
            src="/socials/gmail.svg"
            alt="email"
          />
        </a>
        <a
          href="https://www.instagram.com/devlabs.asu/"
          class="transition-transform duration-200 ease-in-out hover:scale-110"
        >
          <img
            class="w-6 h-6 opacity-70 hover:opacity-100 transition-opacity duration-200 ease-in-out"
            src="/socials/instagram.svg"
            alt="insta"
          />
        </a>
        <a
          href="https://discord.gg/4XPKg2nWcj"
          class="transition-transform duration-200 ease-in-out hover:scale-110"
        >
          <img
            class="w-6 h-6 opacity-70 hover:opacity-100 transition-opacity duration-200 ease-in-out"
            src="/socials/discord.svg"
            alt="discord"
          />
        </a>
      </div>
    </div>
  </div>
</nav>

<style>
  nav {
    /* Additional glassmorphism support for older browsers */
    -webkit-backdrop-filter: blur(16px);
  }

  /* Enhanced glass effect with subtle highlight - only for main container */
  nav > div {
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.15) 0%,
      rgba(255, 255, 255, 0.05) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.2),
      inset 0 1px 1px rgba(255, 255, 255, 0.1);
  }

  /* Mobile menu glass effect */
  #mobile-menu {
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.15) 0%,
      rgba(255, 255, 255, 0.05) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.2),
      inset 0 1px 1px rgba(255, 255, 255, 0.1);
  }

  /* Active link styling */
  .nav-link.active {
    color: white;
    font-weight: 600;
  }

  /* Orange highlight styling */
  #active-highlight {
    background: linear-gradient(
      135deg,
      rgba(255, 153, 0, 0.8) 0%,
      rgba(255, 102, 0, 0.6) 100%
    );
    box-shadow: 0 2px 8px rgba(255, 153, 0, 0.3);
    backdrop-filter: blur(2px);
  }

  /* Mobile responsive adjustments */
  @media (max-width: 768px) {
    nav {
      top: 1rem;
      left: 1rem;
      right: 1rem;
      transform: none;
      width: auto;
    }

    nav > div {
      padding: 0.75rem 1rem;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const navLinks = document.querySelectorAll(".nav-link");
    const highlight = document.getElementById("active-highlight");
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const joinUsLink = document.getElementById("join-us-link");
    const joinUsLinkMobile = document.getElementById("join-us-link-mobile");

    // Function to update join us links based on auth status
    const updateJoinUsLinks = async () => {
      try {
        const response = await fetch("/api/auth/me", {
          method: "GET",
          credentials: "include",
        });

        if (response.ok) {
          const data = await response.json();
          if (data.user) {
            // User is logged in - point to dashboard
            if (joinUsLink) {
              joinUsLink.setAttribute("href", "/dashboard");
            }
            if (joinUsLinkMobile) {
              joinUsLinkMobile.setAttribute("href", "/dashboard");
            }
          } else {
            // User is not logged in - point to registration
            if (joinUsLink) {
              joinUsLink.setAttribute("href", "/register");
            }
            if (joinUsLinkMobile) {
              joinUsLinkMobile.setAttribute("href", "/register");
            }
          }
        }
      } catch (error) {
        console.log("Auth check failed:", error);
        // Default to registration page
        if (joinUsLink) {
          joinUsLink.setAttribute("href", "/register");
        }
        if (joinUsLinkMobile) {
          joinUsLinkMobile.setAttribute("href", "/register");
        }
      }
    };

    // Update join us links on page load
    updateJoinUsLinks();

    // Mobile menu toggle functionality
    if (mobileMenuBtn && mobileMenu) {
      mobileMenuBtn.addEventListener("click", function () {
        const isOpen =
          !mobileMenu.classList.contains("hidden") &&
          !mobileMenu.classList.contains("scale-y-0");

        if (!isOpen) {
          // Open menu
          mobileMenu.classList.remove("hidden");
          // Trigger animation after a small delay to ensure display change
          setTimeout(() => {
            mobileMenu.classList.remove("scale-y-0", "opacity-0");
            mobileMenu.classList.add("scale-y-100", "opacity-100");
          }, 10);

          // Animate icon to X with rotation
          mobileMenuBtn.innerHTML = `
                    <svg class="w-6 h-6 transform rotate-90 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                `;
        } else {
          // Close menu
          mobileMenu.classList.add("scale-y-0", "opacity-0");
          mobileMenu.classList.remove("scale-y-100", "opacity-100");

          // Wait for animation to complete before hiding
          setTimeout(() => {
            mobileMenu.classList.add("hidden");
          }, 300);

          // Animate icon back to hamburger with rotation
          mobileMenuBtn.innerHTML = `
                    <svg class="w-6 h-6 transform -rotate-90 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                `;
        }
      });

      // Close mobile menu when clicking on a link
      const mobileNavLinks = mobileMenu.querySelectorAll("a");
      mobileNavLinks.forEach((link) => {
        link.addEventListener("click", function () {
          if (mobileMenu && mobileMenuBtn) {
            // Animate menu closing
            mobileMenu.classList.add("scale-y-0", "opacity-0");
            mobileMenu.classList.remove("scale-y-100", "opacity-100");

            // Wait for animation to complete before hiding
            setTimeout(() => {
              mobileMenu.classList.add("hidden");
            }, 300);

            // Animate icon back to hamburger
            mobileMenuBtn.innerHTML = `
                        <svg class="w-6 h-6 transform -rotate-90 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    `;
          }
        });
      });
    }

    // Function to update active link and highlight position
    function updateActiveLink() {
      const currentPath = window.location.pathname;

      // Update nav links and highlight (desktop only)
      navLinks.forEach((link) => {
        const linkHref = link.getAttribute("href");
        const linkSection = link.getAttribute("data-section");

        // Check if current page matches the link
        if (
          linkHref === currentPath ||
          (currentPath === "/" && linkHref === "/")
        ) {
          link.classList.add("active");

          // Position highlight behind active link
          if (highlight && link.parentElement) {
            const linkRect = link.getBoundingClientRect();
            const navRect = link.parentElement.getBoundingClientRect();
            const offsetX = linkRect.left - navRect.left;

            highlight.style.width = linkRect.width + "px";
            highlight.style.left = offsetX + "px";
            highlight.style.opacity = "1";

            // Add slight rotation variation for each link
            const rotations = {
              story: "-3deg",
              "join-us": "2deg",
              events: "1deg",
              sponsor: "-1deg",
              "find-talent": "3deg",
            };
            highlight.style.transform = `rotate(${rotations[linkSection as keyof typeof rotations] || "-2deg"})`;
          }
        } else {
          link.classList.remove("active");
        }
      });

      // Hide highlight if no link is active
      const hasActiveLink = Array.from(navLinks).some((link) =>
        link.classList.contains("active")
      );
      if (!hasActiveLink && highlight) {
        highlight.style.opacity = "0";
      }
    }

    // Update on page load
    updateActiveLink();
  });
</script>
