---
// components/Polaroid.astro
const { image, rotate = "0deg", top = "10%", left = "auto", right = "auto" } = Astro.props;
---

<div
  class="polaroid hidden md:flex"
  style={`--rotate: ${rotate}; --image-url: url(${image}); top: ${top}; left: ${left}; right: ${right};`}
  aria-hidden="true"
></div>

<style>
.polaroid {
  position: absolute;
  width: 170px;
  height: 190px;
  padding: 8px 8px 16px 8px;
  background: white;
  border: 1px solid rgba(0, 0, 0, 0.1);
  box-shadow: 0 10px 20px rgba(0, 0, 0, 0.25);
  transform: rotate(var(--rotate));
  z-index: 100;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.polaroid::after {
  content: "";
  display: block;
  width: 100%;
  height: 100%;
  background-image: var(--image-url);
  background-size: cover;
  background-position: center;
  border: 1px solid #ccc;
}
</style>
