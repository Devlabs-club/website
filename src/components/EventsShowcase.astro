---
/**
 * EventsShowcase - Cinematic "Poster" style event showcase
 * Features: Film strip navigation, large editorial typography, sticker elements
 */

const events = [
  {
    id: 'devhacks',
    name: 'DevHacks',
    subtitle: 'ASU’s Biggest Hackathon',
    tagline: 'Build Something Amazing in 48 Hours',
    image: '/events/devhacks.jpg',
    stats: {
      primary: '170+ hackers',
      secondary: '$5k in cash prizes'
    },
    sticker: 'Live',
    link: 'https://entrepreneurship.engineering.asu.edu/2025/06/devhacks-2025-ignites-innovation-at-arizona-state-university/',
  },
  {
    id: 'devhouse-sf',
    name: 'DevHouse SF',
    subtitle: 'SF’s Biggest Hiring Stunt',
    tagline: 'Top 100 builders. One house. Infinite potential.',
    image: '/events/devhouse-sf.jpg',
    stats: {
      primary: '100 builders',
      secondary: '$10k in cash'
    },
    sticker: 'SF Edition',
    link: 'https://devhouse.devlabs.club',
  },
  {
    id: 'devhouse',
    name: 'DevHouse',
    subtitle: 'Residential Accelerator',
    tagline: 'Live, Build, Grow Together',
    image: '/events/devhouse.jpeg',
    stats: {
      primary: '6 weeks',
      secondary: '$50k+ funding'
    },
    sticker: 'Batch 1',
    link: 'https://www.gpec.org/news/press-releases/devlabs-launches-hacker-house/',
  },
  {
    id: 'devspace',
    name: 'DevSpace',
    subtitle: 'Flagship Networking Event',
    tagline: 'Where Innovation Meets Collaboration',
    image: '/events/devspace.png',
    stats: {
      primary: '60+ attendees',
      secondary: '25+ collabs'
    },
    sticker: 'Network',
    link: '/events',
  },
];
---

<section
  class="events-showcase relative w-full h-[100vh] min-h-[700px] overflow-hidden bg-black text-white"
  data-parallax-section
  aria-label="DevLabs signature programs"
  id="events-showcase"
>
  <!-- 1. Seamless Section Transitions (Top & Bottom) -->
  <!-- Top Fade (Black to Transparent) -->
  <div class="absolute top-0 left-0 right-0 h-80 bg-gradient-to-b from-black  to-transparent  z-40 pointer-events-none"></div>
  
  <!-- Bottom Fade (Transparent to Black) -->
  <div class="absolute bottom-0 left-0 right-0 h-80 bg-gradient-to-t from-black to-transparent z-40 pointer-events-none"></div>

  <!-- Radial Vignette for "In Scene" focus -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,black_100%)] z-30 pointer-events-none mix-blend-multiply opacity-90"></div>

  <!-- Background Layers (One per event, cross-fading) -->
  {events.map((event, index) => (
    <div
      class={`absolute inset-0 transition-opacity duration-1000 ease-in-out ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`}
      data-bg-index={index}
    >
      {event.image ? (
        <img
          src={event.image}
          alt={event.name}
          class="w-full h-full object-cover scale-105"
          loading={index === 0 ? "eager" : "lazy"}
        />
      ) : (
        /* Gradient placeholder */
        <div class="w-full h-full bg-gradient-to-br from-orange-900 via-black to-gray-900"></div>
      )}
      <!-- Cinematic Overlays -->
      <div class="absolute inset-0 bg-black/30 mix-blend-multiply"></div>
      <div class="absolute inset-0 bg-noise opacity-[0.12] mix-blend-overlay pointer-events-none"></div>
    </div>
  ))}

  <!-- Film Strip Navigation (Top) -->
  <div class="relative z-50 w-full pt-12 pb-4 overflow-visible">
    <!-- Rotated Wrapper with Paper Texture -->
    <div class="transform -rotate-2 origin-center scale-[1.02]">
      <!-- Removed padding (px-4) to span full width -->
      <div class="film-strip-container w-full overflow-x-auto scrollbar-hide relative py-4">
        
        <!-- The Film Strip Itself -->
        <div class="film-strip flex gap-0 min-w-full w-max mx-auto relative transform translate-y-[2px] paper-torn-edge film-hole-mask">
          <!-- Amber Film Background (Solid, mask applied to parent) -->
          <div class="absolute inset-0 bg-gradient-to-b from-[#3d180b] via-[#7c3a18] to-[#3d180b] opacity-95"></div>
          
          <!-- Plastic Gloss Overlay -->
          <div class="absolute inset-0 bg-gradient-to-b from-white/10 to-transparent mix-blend-overlay pointer-events-none"></div>

          <!-- Edge Text (KODAK) - Repeating pattern for full width -->
          <div class="absolute top-[1px] left-0 right-0 h-[14px] overflow-hidden opacity-60 pointer-events-none z-20">
             <div class="flex w-full justify-start gap-32 px-10 font-mono text-[5px] text-[#e8c8b0] tracking-[4px] font-bold select-none whitespace-nowrap">
                {Array(10).fill('KODAK 500-8').map(text => <span>{text}</span>)}
             </div>
          </div>

           <!-- Bottom Edge Text -->
          <div class="absolute bottom-[1px] left-0 right-0 h-[14px] overflow-hidden opacity-60 pointer-events-none z-20 flex items-end">
             <div class="flex w-full justify-start gap-40 px-16 font-mono text-[5px] text-[#e8c8b0] tracking-[4px] font-bold select-none whitespace-nowrap">
                {Array(10).fill(0).map((_, i) => (
                  <><span>{21 + i}</span><span>{21 + i}A</span></>
                ))}
             </div>
          </div>

          {/* Repeat events to fill width */}
          {[...events, ...events, ...events, ...events].map((event, i) => {
            // Map the repeating index back to original event index (0-3)
            const originalIndex = i % events.length;
            return (
              <button
                class={`film-frame relative w-48 h-28 md:w-64 md:h-36 overflow-hidden border-r border-[#3d180b]/50 group transition-all duration-300 hover:brightness-110 focus:outline-none ${i === 0 ? 'active' : 'opacity-70 grayscale-[0.3]'}`}
                data-original-index={originalIndex}
                data-frame-unique-id={i}
                aria-label={`View ${event.name}`}
              >
                <div class="relative w-full h-full p-[14px]"> <!-- Padding to keep image inside sprockets -->
                  {event.image ? (
                    <img
                      src={event.image}
                      alt=""
                      class="w-full h-full object-cover rounded-sm sepia-[0.4] hue-rotate-[-10deg] contrast-125"
                    />
                  ) : (
                    <div class="w-full h-full bg-gradient-to-br from-orange-900 to-black rounded-sm"></div>
                  )}
                  <!-- Amber Tint Overlay -->
                  <div class="absolute inset-[14px] bg-[#7c3a18] mix-blend-color opacity-40 pointer-events-none"></div>
                </div>
                
                <!-- Frame Highlight -->
                <div class="absolute inset-0 border-[0px] border-transparent group-hover:border-white/20 transition-colors pointer-events-none"></div>
              </button>
            );
          })}
        </div>
      </div>
    </div>
  </div>

  <!-- Content Layer -->
  <div class="absolute inset-0 z-[60] pointer-events-none flex flex-col justify-between p-6 md:p-12 lg:p-16 max-w-[1920px] mx-auto w-full">
    <!-- Centered Event Logo + Spotlight -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-[55]">
      <div
        class="event-logo-center relative opacity-90 transition-opacity duration-300"
        data-event-logo-wrap
      >
        <div aria-hidden="true" class="event-logo-spotlight"></div>
        <img
          src="/events/devhacks_logo.svg"
          alt=""
          class="relative z-10 h-20 md:h-28 lg:h-32 w-auto object-contain drop-shadow-2xl"
          loading="eager"
          decoding="async"
          data-event-logo
        />
      </div>
    </div>
    
    <!-- Top Row: Event logo + (sticker, secondary stat, sponsor) -->
    <div class="w-full flex items-center justify-between mt-20 md:mt-12">
      <!-- Spacer (logo moved to center) -->
      <div class="w-[20vw] pt-20" aria-hidden="true"></div>

      <!-- Right side -->
      <div class="flex flex-col items-end gap-10 pointer-events-auto">
        <!-- Sticker Element -->
        <div class="sticker-wrapper transform rotate-12 transition-transform duration-500 hover:rotate-6 hover:scale-110 cursor-default">
          <div class="sticker relative bg-[#f5f5f0] text-black px-4 py-5 shadow-xl">
            <!-- Tape effect -->
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-8 h-6 bg-white/40 rotate-[-5deg] backdrop-blur-[1px] shadow-sm"></div>

            <div class="flex items-center">
              <div class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></div>
              <span class="font-bold text-sm tracking-widest uppercase font-mono" data-sticker-text>
                
              </span>
            </div>
            <!-- Paper texture overlay -->
            <div class="absolute inset-0 bg-noise opacity-20 mix-blend-multiply"></div>
          </div>
        </div>

        <!-- Secondary stat + sponsor (column) -->
        <div class="text-right flex flex-col items-end gap-4">
          <h3 class="font-serif italic text-3xl md:text-5xl lg:text-6xl text-white drop-shadow-lg" style="font-family: 'Times New Roman', Times, serif;" data-stat-secondary>
            
          </h3>

          <!-- Sponsor on Tape -->
          <div class="relative w-48 h-16 transform -rotate-2 opacity-90 hover:scale-105 transition-transform duration-300">
            <img src="/masking-tape.png" alt="" class="absolute inset-0 w-full h-full object-contain scale-125" />
            <div class="absolute inset-0 flex items-center justify-center pt-1 pr-1">
              <img
                src="/sponsors/ph.png"
                alt="Sponsor"
                class="h-6 w-auto"
                loading="eager"
                decoding="async"
                data-sponsor-logo
              />
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Section: Primary Content + Press -->
    <div class="flex flex-col lg:flex-row items-end justify-between w-full gap-8 pointer-events-auto mt-auto">
      
      <!-- Bottom Left: Primary Content -->
      <div class="flex flex-col gap-2 md:gap-4 max-w-4xl">
        <div class="overflow-hidden">
          <h2 class="font-serif italic text-5xl md:text-7xl lg:text-9xl text-white leading-[0.9] tracking-tight drop-shadow-2xl translate-y-0 transition-transform duration-500" style="font-family: 'Times New Roman', Times, serif;" data-stat-primary>
            
          </h2>
        </div>
        
        <div class="flex flex-col md:flex-row md:items-end gap-4 md:gap-8 mt-4">
          <div>
            <p class="text-orange-200/80 font-mono text-sm tracking-widest uppercase mb-1" data-event-subtitle>
              
            </p>
            <h1 class="text-2xl md:text-3xl font-bold text-white tracking-wide" data-event-name>
              
            </h1>
          </div>
        </div>
      </div>

      <!-- Bottom Right: As Seen On (ASU) -->
      <div class="hidden lg:block w-72 mb-2">
        <div class="mb-3 text-[10px] font-mono text-gray-400 uppercase tracking-widest text-right">As Seen On</div>
        <a href="https://news.asu.edu" target="_blank" rel="noopener noreferrer" class="group block p-5 border border-white/10 bg-black/40 backdrop-blur-md hover:bg-white/5 transition-all duration-300 rounded-sm">
            <div class="flex flex-col gap-4">
                <!-- Logo -->
                <div class="h-5 flex items-center">
                    <img src="/asu.png" alt="ASU News" class="h-full w-auto object-contain brightness-0 invert opacity-60 group-hover:opacity-100 transition-opacity duration-300" />
                </div>
                
                <!-- Quote -->
                <p class="text-sm font-medium text-gray-300 leading-relaxed font-serif italic">
                    "A <strong class="text-white font-semibold not-italic">powerhouse for innovation</strong> that is changing how students build."
                </p>
            </div>

            <!-- Metadata -->
            <div class="mt-4 pt-4 border-t border-white/10 flex items-center justify-between text-[10px] text-gray-500 uppercase tracking-widest font-semibold">
                <span>ASU News</span>
                <span>Oct 2023</span>
            </div>
        </a>
      </div>

    </div>
  </div>

</section>

<style>
  /* Torn Paper Edge Effect - Adapted from Winterwind Tutorial */
  .paper-torn-edge {
    position: relative;
    /* 
       Layered drop-shadows to create a THICK paper border.
       1. Top White Border (4px)
       2. Bottom White Border (4px)
       3. Dark Shadow for depth
    */
    filter: 
      drop-shadow(0 -4px 0 rgba(240, 240, 240, 0.95)) 
      drop-shadow(0 4px 0 rgba(240, 240, 240, 0.95)) 
      drop-shadow(0 12px 20px rgba(0,0,0,0.6));
    
    /* 
       Exact polygon rhythm from Winterwind tutorial:
       1% 0%, 4% 100%, 9% 0%, 13% 100%, 19% 1%, 21% 100%, 26% 5%, 30% 100%, 36% 2%, 43% 100%, 50% 1%, 52% 100%, 61% 0%, 69% 94%, 70% 0%, 76% 100%, 81% 0%, 84% 100%, 91% 0%, 97% 100%, 99% 3%
       
       Converted 100% height to 3px/4px to fit the film strip border without cutting content.
    */
    clip-path: polygon(
      /* Top Edge */
      0% 4px, 
      1% 0px, 
      4% 4px, 
      9% 0px, 
      13% 4px, 
      19% 0px, 
      21% 4px, 
      26% 1px, 
      30% 4px, 
      36% 0px, 
      43% 4px, 
      50% 0px, 
      52% 4px, 
      61% 0px, 
      69% 3px, 
      70% 0px, 
      76% 4px, 
      81% 0px, 
      84% 4px, 
      91% 0px, 
      97% 4px, 
      99% 1px, 
      100% 4px,
      
      /* Right Edge */
      100% 100%,
      
      /* Bottom Edge (Inverse) */
      100% calc(100% - 4px),
      99% calc(100% - 1px),
      97% calc(100% - 4px),
      91% calc(100% - 0px),
      84% calc(100% - 4px),
      81% calc(100% - 0px),
      76% calc(100% - 4px),
      70% calc(100% - 0px),
      69% calc(100% - 3px),
      61% calc(100% - 0px),
      52% calc(100% - 4px),
      50% calc(100% - 0px),
      43% calc(100% - 4px),
      36% calc(100% - 0px),
      30% calc(100% - 4px),
      26% calc(100% - 1px),
      21% calc(100% - 4px),
      19% calc(100% - 0px),
      13% calc(100% - 4px),
      9% calc(100% - 0px),
      4% calc(100% - 4px),
      1% calc(100% - 0px),
      0% calc(100% - 4px)
    );
  }

  /* Add a white rough border to simulate the paper fiber edge */
  .paper-torn-edge::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #e8e8e8; /* Off-white paper color */
    z-index: -1;
  }
  
  /* Inner shadow to give depth to the tear */
  .paper-torn-edge::after {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: inset 0 2px 8px rgba(0,0,0,0.5), inset 0 -2px 8px rgba(0,0,0,0.5);
    pointer-events: none;
    z-index: 2;
  }

  /* Film Hole Mask - Creates transparent sprocket holes */
  .film-hole-mask {
    /* 1. Top Sprockets */
    /* 2. Bottom Sprockets */
    /* 3. Solid Middle */
    mask-image: 
      url("data:image/svg+xml,%3Csvg width='14' height='12' viewBox='0 0 14 12' xmlns='http://www.w3.org/2000/svg'%3E%3Cdefs%3E%3Cmask id='h'%3E%3Crect width='14' height='12' fill='white'/%3E%3Crect x='3' y='1' width='8' height='10' rx='1.5' fill='black'/%3E%3C/mask%3E%3C/defs%3E%3Crect width='14' height='12' fill='black' mask='url(%23h)'/%3E%3C/svg%3E"),
      url("data:image/svg+xml,%3Csvg width='14' height='12' viewBox='0 0 14 12' xmlns='http://www.w3.org/2000/svg'%3E%3Cdefs%3E%3Cmask id='h'%3E%3Crect width='14' height='12' fill='white'/%3E%3Crect x='3' y='1' width='8' height='10' rx='1.5' fill='black'/%3E%3C/mask%3E%3C/defs%3E%3Crect width='14' height='12' fill='black' mask='url(%23h)'/%3E%3C/svg%3E"),
      linear-gradient(to bottom, transparent 14px, black 14px, black calc(100% - 14px), transparent calc(100% - 14px));
    
    -webkit-mask-image: 
      url("data:image/svg+xml,%3Csvg width='14' height='12' viewBox='0 0 14 12' xmlns='http://www.w3.org/2000/svg'%3E%3Cdefs%3E%3Cmask id='h'%3E%3Crect width='14' height='12' fill='white'/%3E%3Crect x='3' y='1' width='8' height='10' rx='1.5' fill='black'/%3E%3C/mask%3E%3C/defs%3E%3Crect width='14' height='12' fill='black' mask='url(%23h)'/%3E%3C/svg%3E"),
      url("data:image/svg+xml,%3Csvg width='14' height='12' viewBox='0 0 14 12' xmlns='http://www.w3.org/2000/svg'%3E%3Cdefs%3E%3Cmask id='h'%3E%3Crect width='14' height='12' fill='white'/%3E%3Crect x='3' y='1' width='8' height='10' rx='1.5' fill='black'/%3E%3C/mask%3E%3C/defs%3E%3Crect width='14' height='12' fill='black' mask='url(%23h)'/%3E%3C/svg%3E"),
      linear-gradient(to bottom, transparent 14px, black 14px, black calc(100% - 14px), transparent calc(100% - 14px));

    mask-position: 
      0 2px, 
      0 calc(100% - 2px), 
      0 0;
    -webkit-mask-position: 
      0 2px, 
      0 calc(100% - 2px), 
      0 0;
      
    mask-size: 
      14px 12px, 
      14px 12px, 
      100% 100%;
    -webkit-mask-size: 
      14px 12px, 
      14px 12px, 
      100% 100%;
      
    mask-repeat: 
      repeat-x, 
      repeat-x, 
      no-repeat;
    -webkit-mask-repeat: 
      repeat-x, 
      repeat-x, 
      no-repeat;
  }

  /* Sticker Styles */
  .sticker {
    clip-path: polygon(
      2% 0%, 98% 1%, 100% 98%, 1% 100%
    );
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.1'/%3E%3C/svg%3E");
  }

  /* Noise Overlay */
  .bg-noise {
    background-image: url("/noise.png");
    background-size: 100px 100px;
  }

  /* Film Strip Scrollbar Hide */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* Active State for Frames */
  .film-frame.active {
    opacity: 1;
    filter: none;
    box-shadow: inset 0 0 0 2px rgba(246, 161, 24, 0.5);
  }

  .event-logo-center {
    /* keep it readable on busy backgrounds */
    filter: drop-shadow(0 25px 60px rgba(0, 0, 0, 0.55));
  }

  .event-logo-spotlight {
    position: absolute;
    inset: -120px -220px;
    z-index: 0;
    border-radius: 9999px;
    background: radial-gradient(
      circle at center,
      rgba(0, 0, 0, 0.85) 0%,
      rgba(0, 0, 0, 0.55) 35%,
      rgba(0, 0, 0, 0.18) 60%,
      rgba(0, 0, 0, 0) 75%
    );
    filter: blur(18px);
    opacity: 0.95;
  }
</style>

<script is:inline>
  (function () {
    function initPoster() {
      const section = document.getElementById('events-showcase');
      if (!section) return;

      // Avoid double-binding listeners for the same section instance
      if (section.dataset.posterInitialized === 'true') return;
      section.dataset.posterInitialized = 'true';

      const events = [
        {
          id: 'devhacks',
          name: 'DevHacks',
          subtitle: 'ASU’s Biggest Hackathon',
          tagline: 'Build Something Amazing in 48 Hours',
          image: '/events/devhacks.jpg',
          logo: '/events/devhacks_logo.svg',
          stats: {
            primary: '170+ hackers',
            secondary: '$5k in cash prizes',
          },
          sticker: 'Live',
          sponsorLogo: '/sponsors/ph.png',
          link: 'https://entrepreneurship.engineering.asu.edu/2025/06/devhacks-2025-ignites-innovation-at-arizona-state-university/',
        },
        {
          id: 'devhouse-sf',
          name: 'DevHouse SF',
          subtitle: 'SF’s Biggest Hiring Stunt',
          tagline: 'Top 100 builders. One house. Infinite potential.',
          image: '/events/devhouse-sf.jpg',
          logo: '/events/devhouse_logo.png',
          stats: {
            primary: '100 builders',
            secondary: '$10k in cash',
          },
          sticker: 'SF Edition',
          sponsorLogo: '/sponsors/deepmind.png',
          link: 'https://devhouse.devlabs.club',
        },
        {
          id: 'devhouse',
          name: 'DevHouse',
          subtitle: 'Residential Accelerator',
          tagline: 'Live, Build, Grow Together',
          image: '/events/devhouse.jpeg',
          logo: '/events/devhouse_logo.png',
          stats: {
            primary: '6 weeks',
            secondary: '$50k+ funding',
          },
          sticker: 'Batch 1',
          sponsorLogo: '/sponsors/deepmind.png',
          link: 'https://www.gpec.org/news/press-releases/devlabs-launches-hacker-house/',
        },
        {
          id: 'devspace',
          name: 'DevSpace',
          subtitle: 'Flagship Networking Event',
          tagline: 'Where Innovation Meets Collaboration',
          image: '/events/devspace.png',
          logo: '/events/devspace_logo.png',
          stats: {
            primary: '60+ attendees',
            secondary: '25+ collabs',
          },
          sticker: 'Network',
          sponsorLogo: '/asu.png',
          link: '/events',
        },
      ];

      /** @type {HTMLButtonElement[]} */
      const frames = Array.from(section.querySelectorAll('button.film-frame'));
      /** @type {HTMLElement[]} */
      const backgrounds = Array.from(section.querySelectorAll('[data-bg-index]'));

      // Text Elements
      /** @type {HTMLElement|null} */
      const primaryStat = section.querySelector('[data-stat-primary]');
      /** @type {HTMLElement|null} */
      const secondaryStat = section.querySelector('[data-stat-secondary]');
      /** @type {HTMLElement|null} */
      const stickerText = section.querySelector('[data-sticker-text]');
      /** @type {HTMLElement|null} */
      const eventName = section.querySelector('[data-event-name]');
      /** @type {HTMLElement|null} */
      const eventSubtitle = section.querySelector('[data-event-subtitle]');
      /** @type {HTMLElement|null} */
      const eventLogoWrap = section.querySelector('[data-event-logo-wrap]');
      /** @type {HTMLImageElement|null} */
      const eventLogo = section.querySelector('[data-event-logo]');
      /** @type {HTMLImageElement|null} */
      const sponsorLogo = section.querySelector('[data-sponsor-logo]');

      let currentIndex = 0;
      let autoAdvanceTimerId = /** @type {number | undefined} */ (undefined);

      /**
       * @param {HTMLElement|null} el
       * @param {string | undefined | null} value
       */
      function setText(el, value) {
        if (!el) return;
        el.textContent = value ?? '';
      }

      function updateContent(index) {
        const event = events[index];
        if (!event) return;

        // Active frame UI (highlight all duplicates for the chosen event)
        frames.forEach((f) => {
          const frameIndex = parseInt(f.getAttribute('data-original-index') || '0', 10);
          if (frameIndex === index) f.classList.add('active');
          else f.classList.remove('active');
        });

        // Background crossfade
        backgrounds.forEach((bg, i) => {
          const isActive = i === index;
          bg.classList.toggle('opacity-100', isActive);
          bg.classList.toggle('z-10', isActive);
          bg.classList.toggle('opacity-0', !isActive);
          bg.classList.toggle('z-0', !isActive);
        });

        // Content swap
        setText(primaryStat, event?.stats?.primary);
        setText(secondaryStat, event?.stats?.secondary);
        setText(stickerText, event?.sticker);
        setText(eventName, event?.name);
        setText(eventSubtitle, event?.subtitle);

        // Event logo (left)
        if (eventLogoWrap) {
          const shouldShow = Boolean(event?.logo);
          eventLogoWrap.classList.toggle('opacity-0', !shouldShow);
          eventLogoWrap.classList.toggle('pointer-events-none', !shouldShow);
        }
        if (eventLogo && event?.logo) {
          eventLogo.src = event.logo;
          eventLogo.alt = `${event.name} logo`;
        }

        // Sponsor logo (on tape)
        if (sponsorLogo && event?.sponsorLogo) {
          sponsorLogo.src = event.sponsorLogo;
          sponsorLogo.alt = `${event.name} sponsor`;
        }
      }

      function startAutoAdvance() {
        if (autoAdvanceTimerId) window.clearInterval(autoAdvanceTimerId);
        autoAdvanceTimerId = window.setInterval(() => {
          currentIndex = (currentIndex + 1) % events.length;
          updateContent(currentIndex);
        }, 5_000);
      }

      frames.forEach((frame) => {
        frame.addEventListener('click', (e) => {
          e.preventDefault();
          const index = parseInt(frame.getAttribute('data-original-index') || '0', 10);
          if (!Number.isFinite(index)) return;
          if (index === currentIndex) return;
          currentIndex = index;
          updateContent(index);
          startAutoAdvance();
        });
      });

      // Ensure initial state is consistent (active highlight + content)
      updateContent(0);
      startAutoAdvance();
    }

    // Run after DOM is ready (Astro can hoist non-inline scripts)
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPoster, { once: true });
    } else {
      initPoster();
    }

    // Also re-init after Astro client navigation (if enabled)
    document.addEventListener('astro:page-load', initPoster);
  })();
</script>
