---

<section
  class="events-parallax"
  data-events-parallax
  aria-label="Devlabs events story"
>
  <!-- GLOW EFFECT (fixed eclipse, behind text and collage) -->
  <div
    class="events-parallax__glow"
    data-events-parallax-glow
    aria-hidden="true"
  >
  </div>

  <!-- TEXT STAGE (centered, fixed during scroll) -->
  <div class="events-parallax__text-stage" data-events-parallax-text>
    <div class="events-parallax__lines">
      <!-- Line 1: text-start -->
      <p
        class="events-parallax__line events-parallax__line--start"
        data-events-parallax-line
      >
        <span class="events-parallax__muted">we are a</span>
        <span class="events-parallax__emphasis">500+ builder community</span>
      </p>
      <!-- Line 2: center with 20% padding right -->
      <p
        class="events-parallax__line events-parallax__line--center-left"
        data-events-parallax-line
      >
        <span class="events-parallax__muted">raised over</span>
        <span class="events-parallax__emphasis">125k in funding</span>
      </p>
      <!-- Line 3: center with 20% padding left -->
      <p
        class="events-parallax__line events-parallax__line--center-right"
        data-events-parallax-line
      >
        <span class="events-parallax__muted">more than</span>
        <span class="events-parallax__emphasis">170+ projects built</span>
      </p>
      <!-- Line 4: text-end -->
      <p
        class="events-parallax__line events-parallax__line--end"
        data-events-parallax-line
      >
        <span class="events-parallax__muted">to fund the</span>
        <span class="events-parallax__emphasis"
          >next generation of builders</span
        >
      </p>
    </div>
  </div>

  <!-- IMAGE STAGE (bottom, fixed during scroll) -->
  <div class="events-parallax__image-stage" data-events-parallax-image>
    <!-- Stars (same z-index / sticky behavior as collage) -->
    <img
      src="/star.svg"
      alt=""
      aria-hidden="true"
      class="events-parallax__star events-parallax__star--left"
      loading="eager"
      decoding="async"
    />
    <img
      src="/star.svg"
      alt=""
      aria-hidden="true"
      class="events-parallax__star events-parallax__star--right"
      loading="eager"
      decoding="async"
    />

    <!-- Team collage -->
    <div class="events-parallax__collage" aria-hidden="true">
      <img
        src="/team-collage.png"
        alt="Devlabs team collage"
        loading="eager"
        decoding="async"
      />
    </div>
  </div>
</section>

<style>
  @import url("https://api.fontshare.com/v2/css?f[]=open-sauce-sans@400,500&display=swap");

  .events-parallax {
    position: relative;
    height: 250vh;
    background: transparent;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .events-parallax {
      height: 350vh;
    }
  }

  /* GLOW EFFECT - fixed eclipse centered in viewport, behind everything */
  .events-parallax__glow {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.2s ease-out;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(255, 255, 255, 0.15) 0%,
      rgba(255, 255, 255, 0.1) 25%,
      rgba(255, 255, 255, 0.05) 50%,
      transparent 70%
    );
  }

  .events-parallax__glow.is-visible {
    opacity: 1;
  }

  /* TEXT STAGE - centered, toggles between absolute and fixed */
  .events-parallax__text-stage {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 0;
    box-sizing: border-box;
    pointer-events: none;
    z-index: 10;

    /* Gradient mask for smooth fade-out at top */
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(0, 0, 0, 0.3) 5%,
      rgba(0, 0, 0, 0.6) 10%,
      black 18%,
      black 100%
    );
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(0, 0, 0, 0.3) 5%,
      rgba(0, 0, 0, 0.6) 10%,
      black 18%,
      black 100%
    );
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-size: 100% 100%;
    mask-size: 100% 100%;
  }

  .events-parallax__lines {
    position: relative;
    width: 80%;
    height: 300px;
  }

  .events-parallax__line {
    position: absolute;
    left: 0;
    right: 0;
    margin: 0;
    transition: all 300ms ease-out;
    opacity: 0;
    will-change: transform, opacity;
    width: 100%;
  }

  /* Line 1: text-start (left aligned) */
  .events-parallax__line--start {
    text-align: left;
  }

  /* Line 2: center with 20% padding from right */
  .events-parallax__line--center-left {
    text-align: center;
    padding-right: 20%;
  }

  /* Line 3: center with 20% padding from left */
  .events-parallax__line--center-right {
    text-align: center;
    padding-left: 20%;
  }

  /* Line 4: text-end (right aligned) */
  .events-parallax__line--end {
    text-align: right;
  }

  .events-parallax__muted {
    font-family:
      "Open Sauce Sans",
      "Open Sauce",
      system-ui,
      -apple-system,
      "Segoe UI",
      sans-serif;
    font-weight: 400;
    color: #6b7280;
    font-size: 1.25rem;
    margin-right: 0.5rem;
  }

  .events-parallax__emphasis {
    font-family: "Times New Roman", Times, Georgia, serif;
    font-style: italic;
    font-size: 2rem;
    color: #fff;
  }

  @media (min-width: 640px) {
    .events-parallax__muted {
      font-size: 1.5rem;
    }
    .events-parallax__emphasis {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 768px) {
    .events-parallax__muted {
      font-size: 1.75rem;
    }
    .events-parallax__emphasis {
      font-size: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .events-parallax__muted {
      font-size: 2rem;
    }
    .events-parallax__emphasis {
      font-size: 3.5rem;
    }
  }

  @media (min-width: 1280px) {
    .events-parallax__muted {
      font-size: 2.25rem;
    }
    .events-parallax__emphasis {
      font-size: 4rem;
    }
  }

  /* IMAGE STAGE - bottom, toggles between absolute and fixed */
  .events-parallax__image-stage {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 100vh;
    width: 100vw;
    pointer-events: none;
    will-change: transform;
    z-index: 20;
    overflow: hidden;

    /* Gradient mask for smooth fade at bottom */
    -webkit-mask-image: linear-gradient(
      to bottom,
      black 0%,
      black 60%,
      rgba(0, 0, 0, 0.8) 75%,
      rgba(0, 0, 0, 0.4) 88%,
      rgba(0, 0, 0, 0.1) 95%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      black 0%,
      black 60%,
      rgba(0, 0, 0, 0.8) 75%,
      rgba(0, 0, 0, 0.4) 88%,
      rgba(0, 0, 0, 0.1) 95%,
      transparent 100%
    );
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-size: 100% 100%;
    mask-size: 100% 100%;
  }

  .events-parallax__collage {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
  }

  .events-parallax__collage img {
    width: 100%;
    object-fit: contain;
    display: block;
  }

  .events-parallax__star {
    position: absolute;
    pointer-events: none;
    user-select: none;
    opacity: 0.9;
    filter: drop-shadow(0 22px 60px rgba(0, 0, 0, 0.55));
  }

  /* Big star: left center, with good side margin */
  .events-parallax__star--left {
    left: clamp(16px, 4vw, 64px);
    top: 50%;
    transform: translateY(-50%);
    width: clamp(140px, 18vw, 240px);
    height: auto;
  }

  /* Small star: right top, with good side margin */
  .events-parallax__star--right {
    right: clamp(16px, 4vw, 64px);
    top: clamp(14px, 6vh, 72px);
    width: clamp(64px, 9vw, 120px);
    height: auto;
    opacity: 0.85;
  }

  @media (max-width: 640px) {
    .events-parallax__star--left {
      width: clamp(110px, 28vw, 170px);
      opacity: 0.8;
    }
    .events-parallax__star--right {
      width: clamp(52px, 16vw, 90px);
      opacity: 0.75;
    }
  }
</style>

<script>
  import { initEventsParallax } from "../lib/scroll.js";
  initEventsParallax();
</script>
